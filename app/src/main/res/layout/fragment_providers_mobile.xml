<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.providers.ProvidersMobileFragment">

    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_wallpaper_mobile"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:src="@drawable/ic_providers_language"
        android:tint="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/s_providers_language"
        app:layout_constraintEnd_toStartOf="@id/s_providers_language"
        app:layout_constraintTop_toTopOf="@id/s_providers_language"
        tools:ignore="ContentDescription,UseAppTint" />

    <Spinner
        android:id="@+id/s_providers_language"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_providers_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="64dp"
        android:layout_marginEnd="64dp"
        android:gravity="center"
        android:text="@string/providers_choose_title"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/iv_downloads"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_downloads" />

    <!-- 2026-05-20 : cœur favoris global, centré à la place du titre "Fournisseur" -->
    <ImageView
        android:id="@+id/iv_global_favorites"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:padding="4dp"
        android:src="@drawable/ic_favorite_enable"
        android:tint="#E50914"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Favoris"
        app:layout_constraintBottom_toBottomOf="@id/iv_downloads"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_downloads"
        tools:ignore="HardcodedText,UseAppTint" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tl_provider_groups"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="32dp"
        android:background="@android:color/transparent"
        app:tabIndicatorColor="#FFFFFF"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="#AAFFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_providers_label">
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Films / Séries" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Animés" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TV / IPTV" />
    </com.google.android.material.tabs.TabLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_providers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="64dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="64dp"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="32dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tl_provider_groups"
        app:spanCount="2"
        tools:itemCount="3"
        tools:listitem="@layout/item_provider_mobile" />

    <include
        android:id="@+id/is_loading"
        layout="@layout/layout_is_loading_mobile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_downloads"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        android:padding="10dp"
        android:src="@drawable/ic_downloads"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/downloads"
        app:tint="@android:color/white"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-05-05 : Bouton cadenas pour le contrôle parental -->
    <ImageView
        android:id="@+id/iv_parental_lock"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="12dp"
        android:padding="10dp"
        android:src="@drawable/ic_lock"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Contrôle parental"
        app:tint="@android:color/white"
        android:elevation="4dp"
        app:layout_constraintEnd_toStartOf="@id/iv_downloads"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-05-08 : Bouton paramètres en haut à gauche pour accès direct
         depuis le Home Fournisseur (raccourci vers l'onglet Paramètres incl.
         "Extracteurs"). Symétrique de iv_downloads à droite. -->
    <ImageView
        android:id="@+id/iv_settings"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:padding="10dp"
        android:src="@drawable/ic_menu_settings"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Paramètres"
        app:tint="@android:color/white"
        android:elevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-05-12 : Bouton "Changer de profil" à côté de Paramètres.
         Retourne à l'écran "Qui regarde ?" (ProfilePickerActivity). -->
    <ImageView
        android:id="@+id/iv_profile_switch"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="12dp"
        android:padding="10dp"
        android:src="@drawable/ic_person_placeholder"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Changer de profil"
        app:tint="@android:color/white"
        android:elevation="4dp"
        app:layout_constraintStart_toEndOf="@id/iv_settings"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>