<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    <!-- 2026-05-13 (user "je voulais seulement mon fond d'écran normal ici, je
         veux voir à travers") : tuile transparente, pas de frame coloré. Focus
         = anneau blanc en foreground uniquement. Le wallpaper du home apparaît
         derrière chaque emoji. -->
    <FrameLayout
        android:id="@+id/fl_profile_avatar"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@android:color/transparent"
        android:foreground="@drawable/fg_profile_avatar_focus"
        android:duplicateParentState="true">

        <TextView
            android:id="@+id/tv_profile_emoji"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="120sp"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="6"
            tools:text="🎬" />

        <!-- 2026-05-20 : avatar Fluent 3D (image, par-dessus l'emoji systeme de
             fallback). Transparent, pas de fond, le wallpaper reste visible. -->
        <ImageView
            android:id="@+id/iv_profile_emoji"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="26dp"
            android:scaleType="fitCenter"
            android:visibility="gone"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/iv_profile_lock"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="12dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_lock"
            android:visibility="gone"
            app:tint="#FFFFFF"
            tools:ignore="ContentDescription" />
    </FrameLayout>

    <!-- 2026-05-13 (user "y a pas marqué à qui appartient le profil") : nom du
         profil bien visible sous l'avatar — bold + ombre noire pour contraster
         sur n'importe quel wallpaper (clair ou foncé). -->
    <TextView
        android:id="@+id/tv_profile_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:shadowColor="#CC000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="6"
        tools:text="Principal" />

</LinearLayout>
