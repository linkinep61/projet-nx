<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- WebView : caché par défaut. Rendue visible seulement si le captcha
         requiert une interaction (timeout 5s sans auto-résolution). -->
    <WebView
        android:id="@+id/pds_captcha_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <!-- Overlay minimaliste : centre, juste un spinner + message + bouton Annuler.
         Couvre toute l'écran tant que le captcha se résout en arrière-plan. -->
    <LinearLayout
        android:id="@+id/pds_captcha_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#000000"
        android:padding="32dp">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="#FF6600" />

        <TextView
            android:id="@+id/pds_captcha_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Vérification de sécurité…"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pds_captcha_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Cloudflare en cours…"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

        <!-- Progress bar invisible mais utilisée par l'activity pour le %
             chargement WebView. -->
        <ProgressBar
            android:id="@+id/pds_captcha_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="20dp"
            android:indeterminate="true"
            android:visibility="invisible"
            android:indeterminateTint="#FF6600" />

        <Button
            android:id="@+id/pds_captcha_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="Annuler"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="#333333"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

    </LinearLayout>

</FrameLayout>
