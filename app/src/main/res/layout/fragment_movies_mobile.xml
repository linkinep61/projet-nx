<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.movies.MoviesMobileFragment">

    <LinearLayout
        android:id="@+id/tab_language"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="#1A1A2E"
        android:baselineAligned="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tab_fr"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="FR"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="#33E50914" />

        <TextView
            android:id="@+id/tab_vostfr"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="VOSTFR"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <!-- 2026-05-13 (user "il y a pas de filtre de catégorie et de langue en
         film et série") : barre des 2 boutons IPTV (catégories + filtre
         langue) en haut. Visible seulement pour MyIptvProvider. -->
    <LinearLayout
        android:id="@+id/ll_iptv_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tab_language"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_iptv_categories"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:padding="8dp"
            android:src="@drawable/ic_categories_filter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Catégories Films"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/iv_iptv_language"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_iptv_language"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Filtre langue"
            app:tint="@android:color/white" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_movies"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:padding="10dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_iptv_actions"
        app:spanCount="3"
        tools:listitem="@layout/item_movie_grid_mobile" />

    <include
        android:id="@+id/is_loading"
        layout="@layout/layout_is_loading_mobile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_language" />

</androidx.constraintlayout.widget.ConstraintLayout>