<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#181818">

    <!-- Bouton fermer -->
    <TextView
        android:id="@+id/btn_sync_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="44dp"
        android:layout_marginStart="20dp"
        android:padding="8dp"
        android:text="✕ Fermer"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_sync_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="Synchroniser"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_sync_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:text="Transfère tes données (favoris, sources IPTV, préférences…) entre ton téléphone et ta TV."
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_sync_title" />

    <!-- ══ Écran 1 : choix envoi / réception ══ -->
    <LinearLayout
        android:id="@+id/layout_choice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_sync_subtitle">

        <Button
            android:id="@+id/btn_send"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:padding="16dp"
            android:text="📤  Envoyer mes données"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/bg_tv_button_focus"
            android:focusable="true" />

        <Button
            android:id="@+id/btn_receive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="📥  Recevoir des données"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/bg_tv_button_focus"
            android:focusable="true" />

    </LinearLayout>

    <!-- ══ Écran 2a : envoi — affichage du code ══ -->
    <LinearLayout
        android:id="@+id/layout_send"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_sync_subtitle">

        <ProgressBar
            android:id="@+id/pb_send"
            android:layout_width="56dp"
            android:layout_height="56dp"
            style="?android:attr/progressBarStyle"
            android:indeterminateTint="#4A90E2"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_send_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Entre ce code sur l'autre appareil :"
            android:textColor="#AAAAAA"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_send_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="#4A90E2"
            android:textSize="48sp"
            android:textStyle="bold"
            android:letterSpacing="0.3"
            android:fontFamily="monospace"
            tools:text="A3F 29K"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_send_expires"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Ce code expire dans 5 minutes."
            android:textColor="#888888"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Résultat (succès / erreur) -->
        <TextView
            android:id="@+id/tv_send_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="16sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ══ Écran 2b : réception — saisie du code ══ -->
    <LinearLayout
        android:id="@+id/layout_receive"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_sync_subtitle">

        <TextView
            android:id="@+id/tv_receive_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entre le code affiché sur l'autre appareil :"
            android:textColor="#AAAAAA"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/et_receive_code"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:gravity="center"
            android:hint="______"
            android:maxLength="6"
            android:inputType="textCapCharacters|textNoSuggestions"
            android:background="@drawable/bg_tv_button_focus"
            android:padding="16dp"
            android:focusable="true"
            android:imeOptions="actionDone" />

        <Button
            android:id="@+id/btn_receive_confirm"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="14dp"
            android:text="Synchroniser"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/bg_tv_button_focus"
            android:focusable="true" />

        <ProgressBar
            android:id="@+id/pb_receive"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            style="?android:attr/progressBarStyle"
            android:indeterminateTint="#4A90E2"
            android:visibility="gone" />

        <!-- Résultat -->
        <TextView
            android:id="@+id/tv_receive_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="16sp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
