<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_extractor_stats"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?android:attr/colorPrimary"
        app:title="Extracteurs"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@drawable/ic_back_white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_extractor_stats_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary"
        android:text="Échecs consécutifs (depuis dernier succès) — un extracteur disparaît dès qu'il remarche"
        app:layout_constraintTop_toBottomOf="@id/toolbar_extractor_stats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_extractor_failures"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_extractor_stats_header"
        app:layout_constraintBottom_toTopOf="@id/btn_extractor_stats_actions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_extractor_stats_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aucun échec d'extraction enregistré"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rv_extractor_failures"
        app:layout_constraintBottom_toBottomOf="@id/rv_extractor_failures"
        app:layout_constraintStart_toStartOf="@id/rv_extractor_failures"
        app:layout_constraintEnd_toEndOf="@id/rv_extractor_failures"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/btn_extractor_stats_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_extractor_stats_copy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_extractor_button_focusable"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:focusable="true"
            android:nextFocusRight="@id/btn_extractor_stats_telegram"
            android:text="Copier" />

        <Button
            android:id="@+id/btn_extractor_stats_telegram"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.4"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_extractor_button_focusable"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:focusable="true"
            android:nextFocusLeft="@id/btn_extractor_stats_copy"
            android:nextFocusRight="@id/btn_extractor_stats_clear"
            android:text="Rapport Telegram" />

        <Button
            android:id="@+id/btn_extractor_stats_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_extractor_button_focusable"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:focusable="true"
            android:nextFocusLeft="@id/btn_extractor_stats_telegram"
            android:text="Effacer" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
