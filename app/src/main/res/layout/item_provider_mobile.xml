<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/iv_provider_logo"
        android:layout_width="120dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:duplicateParentState="true"
        android:padding="8dp"
        android:scaleType="fitCenter"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <!-- 2026-06-13 (Favorite Providers, porté upstream v1.7.224) :
         étoile en overlay top-right du logo. Visible si le provider est
         dans la liste UserPreferences.favoriteProviders. -->
    <ImageView
        android:id="@+id/iv_favorite_star"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        android:contentDescription="Favori"
        android:src="@drawable/ic_star"
        android:visibility="gone"
        app:tint="#FFD700"
        app:layout_constraintEnd_toEndOf="@id/iv_provider_logo"
        app:layout_constraintTop_toTopOf="@id/iv_provider_logo" />

    <TextView
        android:id="@+id/tv_provider_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_provider_logo"
        tools:text="Provider name" />

    <TextView
        android:id="@+id/tv_provider_language"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:textColor="#808080"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_provider_name"
        tools:text="Provider language" />

</androidx.constraintlayout.widget.ConstraintLayout>