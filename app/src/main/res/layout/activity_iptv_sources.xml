<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#181818">

    <!-- 2026-05-14 (user "l'écriture est pas comme il faudrait à gauche") :
         retiré marginEnd=180dp qui rendait la largeur dispo négative sur mobile.
         marginTop=80dp pour descendre l'ensemble du haut (statut bar + souffle). -->
    <TextView
        android:id="@+id/tv_iptv_sources_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="12dp"
        android:text="Mes sources IPTV"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintEnd_toStartOf="@id/btn_home_loaded"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-05-12 (user "mets un petit bouton Home pour accéder directement à la page
         des chaînes déjà chargée") : raccourci vers MainActivity sur la dernière source
         chargée, sans re-fetch. Visible uniquement si une source est en cache. -->
    <Button
        android:id="@+id/btn_home_loaded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:layout_marginEnd="32dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="🏠 Accueil"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/bg_tv_button_focus"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_iptv_sources_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="32dp"
        android:gravity="center"
        android:text="Aucune source pour l'instant.\nAjoute ta première playlist M3U ou portail Stalker MAG ci-dessous."
        android:textColor="#AAAAAA"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_iptv_sources_title" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_iptv_sources"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:descendantFocusability="afterDescendants"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/btn_add_iptv_source"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_iptv_sources_title"
        tools:itemCount="3" />

    <Button
        android:id="@+id/btn_add_iptv_source"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="32dp"
        android:padding="12dp"
        android:text="+ Ajouter une source"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:background="@drawable/bg_tv_button_focus"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 2026-05-12 (user "fait un système de chargement comme sur les
         vrais IPTV") : overlay loader visible pendant le fetch d'une source. -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="80dp"
                android:layout_height="80dp"
                style="?android:attr/progressBarStyle"
                android:indeterminateTint="#4A90E2" />

            <TextView
                android:id="@+id/tv_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                tools:text="Chargement de la source…" />

        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
