<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.home.HomeTvFragment">

    <ImageView
        android:id="@+id/iv_home_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        tools:ignore="ContentDescription" />

    <!-- Boutons mini player — barre HORIZONTALE en HAUT À GAUCHE de l'écran,
         détachée du mini lecteur. Ordre : ⛶ Agrandir → ⏸ Pause → ✕ Fermer.
         À côté du bouton quitter provider (sidebar). D-pad focusable. -->
    <LinearLayout
        android:id="@+id/mini_player_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:elevation="8dp"
        android:background="#CC000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="70dp"
        android:layout_marginTop="8dp">

        <ImageView
            android:id="@+id/mini_player_channel_logo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:scaleType="fitCenter"
            tools:ignore="ContentDescription" />

        <ProgressBar
            android:id="@+id/mini_player_loading"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            android:indeterminateTintMode="src_in"
            android:indeterminateTint="#FFFFFF" />

        <ImageView
            android:id="@+id/mini_player_fullscreen"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:padding="8dp"
            android:src="@drawable/ic_mini_player_fullscreen"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusRight="@id/mini_player_pause"
            android:nextFocusDown="@id/vgv_home"
            android:nextFocusLeft="@id/home"
            android:contentDescription="Agrandir" />

        <ImageView
            android:id="@+id/mini_player_pause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:padding="8dp"
            android:src="@drawable/ic_mini_player_pause"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/mini_player_fullscreen"
            android:nextFocusRight="@id/mini_player_close"
            android:nextFocusDown="@id/vgv_home"
            android:contentDescription="Pause" />

        <ImageView
            android:id="@+id/mini_player_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/mini_player_pause"
            android:nextFocusDown="@id/vgv_home"
            android:contentDescription="Fermer"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- Mini player = vidéo pure, flush top-right. Pas d'overlay dedans.
         2026-06-24 v3 (user "trop agrandi, réduis") : 0.65 → 0.55 width.
         Ratio 16:9 conservé → height ~31% écran TV (juste un peu plus
         que l'original 0.50 = 28%). Compromis : visible mais ne pousse
         pas la grille trop bas. -->
    <FrameLayout
        android:id="@+id/mini_player_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#FF000000"
        android:elevation="8dp"
        app:layout_constraintWidth_percent="0.55"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/mini_player_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:show_buffering="when_playing"
            app:resize_mode="fit"
            app:surface_type="surface_view" />

        <ImageView
            android:id="@+id/mini_swap_freeze_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:visibility="gone"
            tools:ignore="ContentDescription" />
    </FrameLayout>

    <!-- Nom de chaîne caché — garde le binding fonctionnel -->
    <TextView
        android:id="@+id/mini_player_channel_name"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.leanback.widget.VerticalGridView
        android:id="@+id/vgv_home"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:nextFocusDown="@id/iv_iptv_categories"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:itemCount="1"
        tools:listitem="@layout/content_category_swiper_tv" />

    <!-- 2026-05-13 (user "il faut que tu fasses la même chose pour la TV
         maintenant le même procédé ça serait vraiment cool avec les mêmes
         boutons mais peut-être pas au même endroit") : 2 boutons IPTV top-left
         (catégories + filtre langue) — visibles seulement pour Mon IPTV. Le
         mini-player occupe top-right donc on les met top-left pour pas
         overlapper. Focusable pour D-pad. -->
    <!-- 2026-05-13 (user "non dans la bar de gauche y a la place") : icônes
         placées verticalement dans la colonne gauche, sous les items du
         sidebar nav_main (search/home/films/séries/favoris/settings) — alignées
         pour avoir l'air d'icônes sidebar supplémentaires. -->
    <LinearLayout
        android:id="@+id/ll_iptv_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 2026-05-13 (user "ce serait plus simple de faire haut pour sortir et
             passer par les boutons pour retourner dans la barre") :
             - DPAD_LEFT depuis iv_iptv_categories → sidebar (nav_main item home)
             - DPAD_UP depuis vgv_home → revient sur ces boutons (déjà câblé)
             - DPAD_RIGHT entre catégories ↔ langue (déjà câblé) -->
        <ImageView
            android:id="@+id/iv_iptv_categories"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="8dp"
            android:padding="10dp"
            android:src="@drawable/ic_categories_filter"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusLeft="@id/home"
            android:nextFocusRight="@id/vgv_home"
            android:nextFocusDown="@id/iv_iptv_language"
            android:nextFocusUp="@id/vgv_home"
            android:contentDescription="Catégories IPTV"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/iv_iptv_language"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_iptv_language"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusLeft="@id/home"
            android:nextFocusRight="@id/vgv_home"
            android:nextFocusUp="@id/iv_iptv_categories"
            android:nextFocusDown="@id/iv_vavoo_tunnel"
            android:contentDescription="Filtre langue IPTV"
            app:tint="@android:color/white" />

        <!-- 2026-06-17 (user "il faut faire un bouton de bascule, de base il est
             pas activé et on l'active") : bouton tunnel Vavoo via serveurs free
             VYPN, visible UNIQUEMENT sur Vavoo TV. OFF par défaut. -->
        <ImageView
            android:id="@+id/iv_vavoo_tunnel"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:padding="10dp"
            android:src="@drawable/ic_vavoo_tunnel"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusLeft="@id/home"
            android:nextFocusRight="@id/vgv_home"
            android:nextFocusUp="@id/iv_iptv_language"
            android:contentDescription="Mode tunnel Vavoo (France)"
            android:visibility="gone"
            app:tint="@android:color/white" />
    </LinearLayout>

    <include
        android:id="@+id/is_loading"
        layout="@layout/layout_is_loading_tv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>