<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".fragments.player.PlayerMobileFragment">

    <com.streamflixreborn.streamflix.ui.PlayerMobileView
        android:id="@+id/pv_player"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:controller_layout_id="@layout/content_exo_controller_mobile"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/settings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="fit"
        app:show_buffering="always"
        app:show_next_button="false"
        app:show_previous_button="false"
        app:show_subtitle_button="true"
        app:show_timeout="2000"
        app:surface_type="texture_view" />

    <!-- Mobile port v54 : overlay freeze frame pendant les swaps live IPTV.
         Mêmes constraints que pv_player. visibility=gone par défaut. -->
    <ImageView
        android:id="@+id/swap_freeze_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/pv_player"
        app:layout_constraintEnd_toEndOf="@+id/pv_player"
        app:layout_constraintStart_toStartOf="@+id/pv_player"
        app:layout_constraintTop_toTopOf="@+id/pv_player" />

    <com.streamflixreborn.streamflix.fragments.player.settings.PlayerSettingsMobileView
        android:id="@+id/settings"
        android:layout_width="300dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <!-- 2026-05-09 : Overlay de chargement pendant la recherche servers + extraction.
         Visible pendant State.LoadingServers + LoadingVideo, hidden dès que
         ExoPlayer fire STATE_READY (premier frame prêt). Sans ça l'écran restait
         juste noir et l'user pensait que rien ne se passait.
         2026-05-18 : end=@id/settings au lieu de parent — sinon l'overlay
         clickable=true couvrait aussi la liste serveurs à droite, empêchant
         l'user de la cliquer pendant le loading. -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#B3000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/settings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/loading_overlay_spinner"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminate="true"
                android:indeterminateTint="#FFFFFF" />

            <TextView
                android:id="@+id/loading_overlay_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Chargement…"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <!-- 2026-05-16 : hint clickable. Si l'extracteur galère, user
                 peut tap pour annuler + choisir un autre lecteur. -->
            <TextView
                android:id="@+id/loading_overlay_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="#33FFFFFF"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Toucher pour changer de serveur"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="italic" />
        </LinearLayout>

        <!-- Barre de progression fictive en bas qui s'anime de 0 à 95% sur 5s
             puis stagne à 95% jusqu'à ce que SuccessLoadingVideo cache l'overlay.
             Évite l'effet "ça avance pas, c'est gelé". -->
        <ProgressBar
            android:id="@+id/loading_overlay_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_gravity="bottom"
            android:max="100"
            android:progress="0"
            android:progressTint="#FFFFFF" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_next_episode_overlay"
        android:layout_width="252dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_next_episode_overlay"
        android:clickable="true"
        android:elevation="12dp"
        android:focusable="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/settings"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/iv_next_episode_poster"
            android:layout_width="82dp"
            android:layout_height="46dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@drawable/glide_fallback_cover" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_next_episode_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_next_episode_up_next"
                android:textAllCaps="true"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_next_episode_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="S2 E8" />

            <TextView
                android:id="@+id/tv_next_episode_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="12sp"
                tools:text="Finale" />

            <TextView
                android:id="@+id/tv_next_episode_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp"
                tools:text="Playing next in 8s" />

            <TextView
                android:id="@+id/btn_next_episode_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_next_episode_action"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="@string/player_next_episode_action"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_next_episode_dismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="4dp"
                android:paddingTop="2dp"
                android:paddingEnd="4dp"
                android:paddingBottom="2dp"
                android:text="@string/player_next_episode_dismiss"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_brightness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="32dp"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_brightness_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            tools:text="50%"/>

        <ProgressBar
            android:id="@+id/pb_brightness"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:rotation="270"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="60dp"
            tools:progress="50"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_brightness"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_volume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="32dp"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_volume_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            tools:text="50%"/>

        <ProgressBar
            android:id="@+id/pb_volume"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:rotation="270"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="60dp"
            tools:progress="50"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_player_settings_audio"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- 2026-06-12 (user "crée une page transparente qui verrouille
         carrément le truc, seul le cadenas le déverrouille") :
         Overlay plein écran qui mange TOUS les taps quand visible.
         Cliquable + focusable + intercepte le toucher → rien ne peut
         atteindre le PlayerView ou les contrôles dessous. Le bouton
         btn_screen_unlock est posé PAR-DESSUS l'overlay (= z-order)
         et reste cliquable pour déverrouiller.

         Le fond est volontairement transparent pour ne pas gâcher la
         lecture vidéo. Au tap n'importe où, on flashe brièvement le
         cadenas (3s) puis on le fade out. -->
    <FrameLayout
        android:id="@+id/layout_screen_lock"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#00000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 2026-06-12 (user "le cadenas trop grand au milieu, l'enfant
             va cliquer dessus direct - mets-le en haut a gauche et plus
             petit") : 40dp en top|start avec marges pour qu'il soit
             clairement visible mais pas au centre où un enfant taperait
             par réflexe. -->
        <ImageView
            android:id="@+id/btn_screen_unlock"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:padding="10dp"
            android:src="@drawable/exo_styled_controls_unlock"
            android:contentDescription="Déverrouiller l'écran"
            android:background="@drawable/bg_screen_unlock_circle"
            app:tint="#FFFFFF" />
    </FrameLayout>

    <!-- 2026-06-15 (user "j'arrive pas à prendre le même pattern que TV") :
         Panel liste des chaînes IPTV mobile. Copié sur fragment_player_tv.xml
         ligne 309-397. Width 0dp + layout_constraintWidth_percent réglé par
         le code Kotlin (1.0 portrait, 0.5 paysage). Visible/Invisible via
         setVisibility + translationX. -->
    <LinearLayout
        android:id="@+id/layout_channel_list_mobile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#DD000000"
        android:elevation="20dp"
        android:focusable="false"
        android:orientation="vertical"
        android:padding="0dp"
        android:visibility="gone"
        app:layout_constraintWidth_default="percent"
        app:layout_constraintWidth_percent="0.2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tv_channel_list_title_mobile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chaînes"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:gravity="center_vertical" />

            <Button
                android:id="@+id/btn_channel_list_close_mobile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FERMER"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:background="#33FFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_channel_search_mobile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:background="#22FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:hint="Rechercher une chaîne…"
            android:textColorHint="#88FFFFFF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_channel_list_mobile"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
