<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Bouton URL personnalisée en haut du picker
         2026-06-03 (user "il y a un message tellement petit") : agrandi +
         contrasté + wording explicite (Tenor/Giphy). Avant : OutlinedButton
         minuscule presque invisible sur fond noir. -->
    <Button
        android:id="@+id/btn_custom_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:minHeight="48dp"
        android:paddingVertical="12dp"
        android:text="🔗  Coller une URL d'image (Tenor, Giphy, etc.)"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        style="@style/Widget.MaterialComponents.Button" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_emoji_picker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="6"
        tools:itemCount="30"
        tools:listitem="@layout/item_emoji_picker" />

</LinearLayout>
