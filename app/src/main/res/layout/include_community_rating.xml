<?xml version="1.0" encoding="utf-8"?>
<!-- Widget de notation communautaire — 5 étoiles cliquables + compteur -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ll_community_rating"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:paddingTop="0dp">

    <TextView
        android:id="@+id/tv_community_rating_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Note"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_star_1"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_star"
            android:contentDescription="1 étoile"
            tools:ignore="UseAppTint" />

        <ImageView
            android:id="@+id/iv_star_2"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_star"
            android:contentDescription="2 étoiles"
            tools:ignore="UseAppTint" />

        <ImageView
            android:id="@+id/iv_star_3"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_star"
            android:contentDescription="3 étoiles"
            tools:ignore="UseAppTint" />

        <ImageView
            android:id="@+id/iv_star_4"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_star"
            android:contentDescription="4 étoiles"
            tools:ignore="UseAppTint" />

        <ImageView
            android:id="@+id/iv_star_5"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_star"
            android:contentDescription="5 étoiles"
            tools:ignore="UseAppTint" />

        <TextView
            android:id="@+id/tv_community_rating_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="#C0C0C0"
            android:textSize="14sp"
            tools:text="4.2 (12 votes)" />

    </LinearLayout>

</LinearLayout>
