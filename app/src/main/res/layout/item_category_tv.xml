<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- 2026-05-13 (user "tu peux pas décaler un peu l'écriture et la petite
         parabole vers la droite") : marginStart bumped 70 → 140dp pour libérer
         de la place pour les 2 boutons IPTV top-left (catégories + langue) qui
         occupent ~112dp à partir du bord gauche. Évite l'overlap visuel entre
         "📡 Toutes les chaînes" et les icônes du toolbar. -->
    <TextView
        android:id="@+id/tv_category_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="140dp"
        android:layout_marginEnd="8dp"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/iv_category_clear"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Title" />

    <!-- 2026-06-22 : poubelle pour vider toute la section d'un coup -->
    <ImageView
        android:id="@+id/iv_category_clear"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="70dp"
        android:padding="4dp"
        android:src="@android:drawable/ic_menu_delete"
        android:contentDescription="Tout supprimer"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_category_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_category_title"
        tools:visibility="visible" />

    <!-- 2026-05-13 (user "quand je vais sur la gauche ça m'envoie en haut") :
         force nextFocusLeft sur @id/home (menu sidebar) pour que LEFT depuis
         une tile aille bien sur la sidebar, pas sur les boutons IPTV au-dessus.
         Sans ça, le focus part chercher le focusable le plus proche → IPTV
         button qui est haut-gauche. -->
    <androidx.leanback.widget.HorizontalGridView
        android:id="@+id/hgv_category"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="70dp"
        android:paddingEnd="70dp"
        android:scrollbars="none"
        android:nextFocusLeft="@id/home"
        app:focusOutEnd="true"
        app:focusOutFront="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_category_title" />

</androidx.constraintlayout.widget.ConstraintLayout>