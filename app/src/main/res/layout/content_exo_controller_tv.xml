<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_exo_controller"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@id/exo_controls_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#98000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone" />

    <TextView
        android:id="@+id/tv_exo_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="16dp"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        app:layout_constraintEnd_toStartOf="@id/btn_exo_external_player"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Title" />

    <TextView
        android:id="@+id/tv_exo_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:textSize="20sp"
        app:layout_constraintEnd_toStartOf="@id/btn_exo_external_player"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_exo_title"
        tools:text="Description" />

    <!-- 2026-06-19 v34 (user "TV même chose que mobile : barre avec TOUS
         les icônes tout en haut") : aspect_ratio + external_player
         groupés EN HAUT À DROITE, alignés sur la même ligne. -->
    <ImageView
        android:id="@+id/btn_exo_aspect_ratio"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="7dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="7dp"
        android:background="@drawable/bg_btn_exoplayer_tv"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:nextFocusLeft="@id/btn_exo_aspect_ratio"
        android:nextFocusRight="@id/btn_exo_external_player"
        android:nextFocusDown="@id/exo_play_pause"
        android:padding="12dp"
        android:src="@drawable/exo_styled_controls_aspect_ratio"
        android:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="@id/tv_exo_subtitle"
        app:layout_constraintEnd_toStartOf="@id/btn_exo_external_player"
        app:layout_constraintTop_toTopOf="@id/tv_exo_title"
        tools:ignore="ContentDescription,PrivateResource,UseAppTint" />

    <ImageView
        android:id="@+id/btn_exo_external_player"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="7dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="7dp"
        android:background="@drawable/bg_btn_exoplayer_tv"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:nextFocusLeft="@id/btn_exo_aspect_ratio"
        android:nextFocusRight="@id/btn_exo_external_player"
        android:nextFocusDown="@id/exo_play_pause"
        android:padding="12dp"
        android:src="@drawable/exo_styled_controls_external_player"
        android:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="@id/tv_exo_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_exo_title"
        tools:ignore="ContentDescription,PrivateResource,UseAppTint" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_custom_prev"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_btn_exoplayer_tv"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusRight="@id/exo_replay"
            android:nextFocusUp="@id/tv_exo_subtitle"
            android:nextFocusDown="@id/exo_progress"
            android:padding="10dp"
            android:src="@drawable/ic_previous"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/exo_replay"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_btn_exoplayer_tv"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/btn_custom_prev"
            android:nextFocusRight="@id/exo_play_pause"
            android:nextFocusUp="@id/tv_exo_subtitle"
            android:nextFocusDown="@id/exo_progress"
            android:padding="10dp"
            android:src="@drawable/ic_refresh"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@id/exo_play_pause"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_btn_exoplayer_tv"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/exo_replay"
            android:nextFocusRight="@id/btn_custom_next"
            android:nextFocusUp="@id/btn_exo_aspect_ratio"
            android:nextFocusDown="@id/exo_progress"
            android:padding="2dp"
            android:src="@drawable/exo_styled_controls_play"
            android:tint="#FFFFFF"
            tools:ignore="ContentDescription,PrivateResource,UseAppTint" />

        <ImageView
            android:id="@+id/btn_custom_next"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_btn_exoplayer_tv"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/exo_play_pause"
            android:nextFocusRight="@id/exo_settings"
            android:nextFocusUp="@id/tv_exo_subtitle"
            android:nextFocusDown="@id/exo_progress"
            android:padding="10dp"
            android:src="@drawable/ic_next"
            app:tint="#FFFFFF" />

        <!-- Settings (gear) inline with the playback controls — directly to the right
             of skip-forward (▶▶) so D-pad users go right-right-right to reach it. -->
        <ImageView
            android:id="@+id/exo_settings"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_btn_exoplayer_tv"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/btn_custom_next"
            android:nextFocusRight="@id/exo_settings"
            android:nextFocusUp="@id/tv_exo_subtitle"
            android:nextFocusDown="@id/exo_progress"
            android:padding="14dp"
            android:src="@drawable/exo_styled_controls_settings"
            android:tint="#FFFFFF"
            tools:ignore="ContentDescription,PrivateResource,UseAppTint" />

    </LinearLayout>

    <!-- 2026-05-17 v3 (user "la 2e barre accumule du flux supplémentaire,
         le player switche dessus quand barre 1 finie") : 3 widgets dans un
         même conteneur, on toggle la visibilité selon VOD vs live IPTV.
         - VOD : exo_progress visible (seek bar standard bound au player)
         - Live IPTV : les 2 custom DefaultTimeBar visibles, driven
           manuellement pour montrer barre 1 = chunk N en lecture, barre 2 =
           chunk N+1 pré-chargé en avance. Switch quand barre 1 finit. -->
    <!-- 2026-05-17 v4 (user "60 premières secondes en haut, switch sur la
         2e en dessous") : barres stackées verticalement. Bar 1 (en haut)
         = chunk N en lecture (60s). Bar 2 (en bas) = chunk N+1 pré-chargé
         (60s). Quand bar 1 atteint 60s → thumb passe sur bar 2 (switch).
         Quand bar 2 finit → bar 1 reprend avec chunk N+2.
         Pour VOD, on cache les 2 customs et on montre exo_progress. -->
    <LinearLayout
        android:id="@+id/exo_progress_dual_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="4dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/exo_bottom_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Standard seek bar (VOD) — visible par défaut, hidden pour live IPTV.
             2026-06-19 v34 : nextFocusUp remonte au play/pause (centre).
             aspect_ratio est en haut maintenant. -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@id/exo_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@id/exo_play_pause" />

        <!-- Custom barre 1 (chunk en lecture, en haut) — visible pour live IPTV -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/live_primary_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Custom barre 2 (chunk pré-chargé, en bas) — visible pour live IPTV -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/live_secondary_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:focusable="false"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@id/exo_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@id/exo_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="00:00:00" />

        <TextView
            android:id="@+id/tv_time_separator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="·"
            android:textColor="#B3ffffff"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/exo_position"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@id/exo_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#B3ffffff"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_time_separator"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="00:00:00" />

        <!-- 2026-06-19 v34 : btn_exo_aspect_ratio déplacé EN HAUT
             (= barre top à côté de external_player). Le bottom_bar ne
             contient plus que le timer. -->

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 2026-06-19 v34 (user "passer l'intro en bas") : même bug que mobile —
         exo_progress est dans exo_progress_dual_container (LinearLayout),
         pas direct child du ConstraintLayout. Fix : référencer
         exo_progress_dual_container (direct child). -->
    <TextView
        android:id="@+id/btn_skip_intro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/selector_skip_intro_button"
        android:drawableStart="@drawable/exo_styled_controls_fastforward"
        android:drawablePadding="8dp"
        android:focusable="true"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="@string/player_skip_intro"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/exo_progress_dual_container"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>