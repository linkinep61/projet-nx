<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.home.HomeMobileFragment">

    <ImageView
        android:id="@+id/iv_home_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/bg_wallpaper_mobile"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <!-- Mini Player container (IPTV only, hidden by default) -->
    <FrameLayout
        android:id="@+id/mini_player_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="#FF000000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/mini_player_view"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mini_player_height_mobile"
            app:use_controller="false"
            app:show_buffering="when_playing"
            app:resize_mode="fit"
            app:surface_type="surface_view" />

        <!-- 2026-06-16 : mirror du grand swap_freeze_overlay pour masquer le
             JUMELAGE swap. PixelCopy de la derniere frame du SurfaceView avant
             seekToNextMediaItem. Cache au prochain STATE_READY. -->
        <ImageView
            android:id="@+id/mini_swap_freeze_overlay"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mini_player_height_mobile"
            android:scaleType="fitCenter"
            android:visibility="gone"
            android:contentDescription="@null" />

        <!-- Channel name overlay -->
        <LinearLayout
            android:id="@+id/mini_player_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#80000000"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:id="@+id/mini_player_channel_logo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:scaleType="fitCenter"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/mini_player_channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <ProgressBar
                android:id="@+id/mini_player_loading"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:visibility="gone"
                android:indeterminateTintMode="src_in"
                android:indeterminateTint="#FFFFFF" />

            <ImageView
                android:id="@+id/mini_player_pause"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:padding="4dp"
                android:src="@drawable/ic_mini_player_pause"
                android:scaleType="fitCenter"
                android:contentDescription="Pause" />

            <ImageView
                android:id="@+id/mini_player_fullscreen"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:padding="4dp"
                android:src="@drawable/ic_mini_player_fullscreen"
                android:scaleType="fitCenter"
                android:contentDescription="Fullscreen" />

            <ImageView
                android:id="@+id/mini_player_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:scaleType="fitCenter"
                android:contentDescription="Close"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_home"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mini_player_container"
        tools:itemCount="1"
        tools:listitem="@layout/content_category_swiper_mobile" />

    <include
        android:id="@+id/is_loading"
        layout="@layout/layout_is_loading_mobile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_provider_logo"
        android:layout_width="60dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_provider_logo_home_mobile"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:duplicateParentState="true"
        android:padding="8dp"
        android:importantForAccessibility="no"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_downloads"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_downloads"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/downloads"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-05-13 (user "à côté de l'onglet téléchargement il faudrait mettre
         un icône catégorie") : bouton picker catégorie pour Mon IPTV. Visibilité
         togglée dans HomeMobileFragment selon le provider actif. -->
    <!-- 2026-06-19 v35 (user "le bug du refresh est sur plusieurs providers
         My IPTV et World Live") : décalé en cascade pour ne pas chevaucher
         iv_tvhub_refresh. Position 5e dans la chaîne. -->
    <ImageView
        android:id="@+id/iv_iptv_categories"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_categories_filter"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Catégories IPTV"
        android:visibility="gone"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toStartOf="@id/iv_vavoo_tunnel"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-05-13 (user "tu mets un troisième bouton à côté de téléchargement
         ça peut être pas mal pour ce provider") : bouton globe pour switcher
         entre Auto / Toutes les langues / FR uniquement. -->
    <ImageView
        android:id="@+id/iv_iptv_language"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_iptv_language"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Filtre langue IPTV"
        android:visibility="gone"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toStartOf="@id/iv_downloads"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-06-18 (user "Ton bouton refresh il devrait être Tout en haut à
         côté de La planète") : icône Refresh dans la top-bar TV Hub. Clic =
         clear cache replay + re-fetch GitHub. À gauche du globe. -->
    <ImageView
        android:id="@+id/iv_tvhub_refresh"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:src="@android:drawable/ic_popup_sync"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Actualiser TV Hub"
        android:visibility="gone"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toStartOf="@id/iv_iptv_language"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-06-10 (user "bouton apparent dans la barre") : sélecteur de
         source World TV (style Wiseplay). À gauche du globe. -->
    <!-- 2026-06-19 v35 : décalé en cascade (position 6e), à gauche de
         iv_iptv_categories. -->
    <ImageView
        android:id="@+id/iv_world_live_sources"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_menu_iptv_sources"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Mes sources World TV"
        android:visibility="gone"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toStartOf="@id/iv_iptv_categories"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-05-20 (user "sur les providers compatibles on pourrait choisir par
         quoi trier — toutes régions, FR, etc.") : bouton filtre catalogue,
         visible uniquement sur les providers TMDB (Cloudstream). Même slot que
         iv_iptv_language (jamais affichés en même temps : IPTV vs Cloudstream). -->
    <!-- 2026-06-19 v35 : décalé en cascade (position 7e), à gauche de
         iv_world_live_sources. -->
    <ImageView
        android:id="@+id/iv_catalog_filter"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_categories_filter"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Filtre catalogue"
        android:visibility="gone"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toStartOf="@id/iv_world_live_sources"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2026-06-17 (user "il faut faire un bouton de bascule, de base il est pas
         activé et on l'active") : bouton tunnel Vavoo via serveurs free VYPN,
         visible UNIQUEMENT sur Vavoo TV. OFF par défaut. -->
    <!-- 2026-06-19 v35 (user "Bug grave sur vavoo refresh empilé sur VPN
         décale le bouton VPN sur la gauche") : iv_vavoo_tunnel décalé À
         GAUCHE de iv_tvhub_refresh pour ne plus se superposer. -->
    <ImageView
        android:id="@+id/iv_vavoo_tunnel"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_vavoo_tunnel"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Mode tunnel Vavoo (France)"
        android:visibility="gone"
        app:tint="@android:color/white"
        app:layout_constraintEnd_toStartOf="@id/iv_tvhub_refresh"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>