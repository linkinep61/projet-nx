<?xml version="1.0" encoding="utf-8"?>
<!-- Widget de notation communautaire TV — bloc unique focusable D-pad.
     Gauche/Droite = changer la note, OK = valider. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ll_community_rating"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:paddingTop="0dp">

    <TextView
        android:id="@+id/tv_community_rating_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Note"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Conteneur focusable unique — les étoiles sont des enfants non-focusables,
         le parent gère le D-pad (gauche/droite/OK) via CommunityRatingView -->
    <LinearLayout
        android:id="@+id/ll_star_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:focusable="true"
        android:clickable="true"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:background="?android:attr/selectableItemBackground">

        <ImageView
            android:id="@+id/iv_star_1"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_star"
            android:contentDescription="1 étoile"
            tools:ignore="UseAppTint" />

        <ImageView
            android:id="@+id/iv_star_2"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_star"
            android:contentDescription="2 étoiles"
            tools:ignore="UseAppTint" />

        <ImageView
            android:id="@+id/iv_star_3"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_star"
            android:contentDescription="3 étoiles"
            tools:ignore="UseAppTint" />

        <ImageView
            android:id="@+id/iv_star_4"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_star"
            android:contentDescription="4 étoiles"
            tools:ignore="UseAppTint" />

        <ImageView
            android:id="@+id/iv_star_5"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_star"
            android:contentDescription="5 étoiles"
            tools:ignore="UseAppTint" />

        <TextView
            android:id="@+id/tv_community_rating_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="#C0C0C0"
            android:textSize="14sp"
            tools:text="4.2 (12 votes)" />

    </LinearLayout>

</LinearLayout>
