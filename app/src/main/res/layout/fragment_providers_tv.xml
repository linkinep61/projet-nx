<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.providers.ProvidersTvFragment">

    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_wallpaper_tv"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:src="@drawable/ic_providers_language"
        android:tint="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/s_providers_language"
        app:layout_constraintEnd_toStartOf="@id/s_providers_language"
        app:layout_constraintTop_toTopOf="@id/s_providers_language"
        tools:ignore="ContentDescription,UseAppTint" />

    <Spinner
        android:id="@+id/s_providers_language"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_providers_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="70dp"
        android:layout_marginEnd="8dp"
        android:gravity="center"
        android:text="@string/providers_choose_title"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/rv_providers"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- 2026-05-20 : cœur favoris global, centré à la place du titre "Fournisseur".
         Focusable D-pad (bg_tv_button_focus), rouge. -->
    <ImageView
        android:id="@+id/btn_global_favorites"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:padding="10dp"
        android:src="@drawable/ic_favorite_enable"
        android:tint="#E50914"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:contentDescription="Favoris"
        android:background="@drawable/bg_tv_button_focus"
        app:layout_constraintBottom_toBottomOf="@id/tv_providers_label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_providers_label"
        tools:ignore="UseAppTint" />

    <ImageView
        android:id="@+id/btn_providers_downloads"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="32dp"
        android:padding="10dp"
        android:src="@drawable/ic_downloads"
        android:tint="#FFFFFF"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:visibility="gone"
        android:background="@drawable/bg_tv_button_focus"
        app:layout_constraintBottom_toBottomOf="@id/tv_providers_label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_providers_label"
        tools:ignore="ContentDescription,UseAppTint" />

    <!-- 2026-05-08 : Bouton Paramètres en haut à GAUCHE — symétrique du
         cadenas/téléchargements à droite. D-pad friendly via bg_tv_button_focus. -->
    <ImageView
        android:id="@+id/btn_providers_settings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="32dp"
        android:padding="10dp"
        android:src="@drawable/ic_menu_settings"
        android:tint="#FFFFFF"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:contentDescription="Paramètres"
        android:background="@drawable/bg_tv_button_focus"
        app:layout_constraintBottom_toBottomOf="@id/tv_providers_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_providers_label"
        tools:ignore="UseAppTint" />

    <!-- 2026-05-12 : Bouton "Changer de profil" — à droite du bouton Paramètres.
         Permet de revenir à l'écran "Qui regarde ?" sans cold start. -->
    <ImageView
        android:id="@+id/btn_providers_profile_switch"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:padding="10dp"
        android:src="@drawable/ic_person_placeholder"
        android:tint="#FFFFFF"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:contentDescription="Changer de profil"
        android:background="@drawable/bg_tv_button_focus"
        app:layout_constraintBottom_toBottomOf="@id/tv_providers_label"
        app:layout_constraintStart_toEndOf="@id/btn_providers_settings"
        app:layout_constraintTop_toTopOf="@id/tv_providers_label"
        tools:ignore="UseAppTint" />

    <!-- 2026-05-05 : Bouton cadenas pour le contrôle parental.
         Au clic → demande PIN (setup le 1er fois, vérification ensuite) → ouvre
         dialog de gestion des providers verrouillés. -->
    <ImageView
        android:id="@+id/btn_providers_lock"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="32dp"
        android:padding="10dp"
        android:src="@drawable/ic_lock"
        android:tint="#FFFFFF"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:contentDescription="Contrôle parental"
        android:background="@drawable/bg_tv_button_focus"
        app:layout_constraintBottom_toBottomOf="@id/tv_providers_label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_providers_label"
        tools:ignore="UseAppTint" />

    <!--
        TV uses a Leanback theme that does NOT extend Theme.AppCompat.
        Material's TabLayout requires AppCompat theme and crashes the
        Activity at inflation otherwise. We wrap the TabLayout in a
        ContextThemeWrapper via android:theme so Material can find a
        compatible theme just for this view subtree.
    -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tl_provider_groups"
        android:theme="@style/Theme.MaterialComponents.NoActionBar.Bridge"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="70dp"
        android:layout_marginEnd="70dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:tabBackground="@drawable/bg_tab_provider_tv"
        app:tabIndicatorColor="#FFE53935"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabRippleColor="#33E53935"
        app:tabSelectedTextColor="#FFE53935"
        app:tabTextAppearance="@style/TextAppearance.AppCompat.Medium"
        app:tabTextColor="#AAFFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_providers_label">
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Films / Séries" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Animés" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TV / IPTV" />
    </com.google.android.material.tabs.TabLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_providers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="70dp"
        android:paddingTop="@dimen/providers_spacing"
        android:paddingEnd="70dp"
        android:paddingBottom="@dimen/providers_spacing"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tl_provider_groups"
        tools:itemCount="2"
        tools:listitem="@layout/item_provider_tv" />

    <include
        android:id="@+id/is_loading"
        layout="@layout/layout_is_loading_tv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_providers_label" />

</androidx.constraintlayout.widget.ConstraintLayout>