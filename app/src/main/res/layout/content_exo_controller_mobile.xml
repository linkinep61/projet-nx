<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_exo_controller"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <View
        android:id="@+id/exo_controls_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#98000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone" />

    <ImageView
        android:id="@+id/btn_exo_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_player_back"
        app:tint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="@id/tv_exo_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_exo_title"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tv_exo_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintEnd_toStartOf="@id/exo_top_icons_bar"
        app:layout_constraintStart_toEndOf="@id/btn_exo_back"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Title" />

    <TextView
        android:id="@+id/tv_exo_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:textSize="12sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintEnd_toStartOf="@id/exo_top_icons_bar"
        app:layout_constraintStart_toEndOf="@id/btn_exo_back"
        app:layout_constraintTop_toBottomOf="@id/tv_exo_title"
        tools:text="Description" />


    <LinearLayout
        android:id="@+id/exo_center_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_custom_prev"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:src="@drawable/ic_previous"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/exo_rew"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:src="@drawable/exo_styled_controls_rewind"
            app:tint="#FFFFFF"
            tools:ignore="ContentDescription,PrivateResource" />

        <!-- 2026-06-20 : exo_replay (refresh) retiré du centre — le screenshot
             cible ne montre que prev/-10s/play/+10s/next au centre.
             exo_settings (gear) déplacé en haut à droite sous forme de 3-dots. -->

        <!-- Media3's PlayerControlView swaps the drawable at runtime (play↔
             pause) and the runtime swap ignores app:tint, so the button
             ended up rendering black on dark video. Use android:tint here
             specifically so the swap inherits the white color. -->
        <ImageView
            android:id="@+id/exo_play_pause"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:padding="15dp"
            android:src="@drawable/exo_styled_controls_play"
            android:tint="#FFFFFF"
            app:tint="#FFFFFF"
            tools:ignore="ContentDescription,PrivateResource,UseAppTint" />

        <ImageView
            android:id="@+id/exo_ffwd"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:src="@drawable/exo_styled_controls_fastforward"
            app:tint="#FFFFFF"
            tools:ignore="ContentDescription,PrivateResource" />

        <ImageView
            android:id="@+id/btn_custom_next"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:src="@drawable/ic_next"
            app:tint="#FFFFFF" />

    </LinearLayout>

    <!-- Mobile port v51 : conteneur vertical pour exo_progress (VOD) + dual-bars (live IPTV). -->
    <!-- 2026-06-20 (user "la barre cela met bien tout en bas sur mobile") :
         marginBottom 24dp → 0dp. La barre va TOUT EN BAS de l'écran.
         (Antérieurement c'était 24dp suite à une autre demande, mais la nouvelle
          consigne est tout en bas.) -->
    <!-- 2026-06-21 v3 (user "la barre n'est pas encore assez basse, on voit
         bien qu'il y a de la marge encore en bas de l'écran. Là vraiment
         tout en bas") :
         marginBottom -16dp (au lieu de -4dp). DefaultTimeBar a touch_target
         de 24dp (12dp de chaque côté du scrubber) → on tire le container
         de 16dp pour que la LIGNE blanche soit collée au bord bas de
         l'écran. clipChildren=false sur le container ET le parent
         (cl_exo_controller) pour ne pas couper le scrubber. -->
    <LinearLayout
        android:id="@+id/exo_progress_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="-10dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 2026-06-21 v3 (user "le bouton qui est sur la barre tu le fais un
             peu plus gros pour qu'on puisse l'attraper") :
             scrubber_enabled_size 14dp + dragged 20dp = bien grabbable.
             bar_height 4dp (légèrement épaissie, user "grossi un peu").
             touch_target_height 32dp (zone tactile généreuse). -->
        <!-- 2026-06-22 : couleurs forcées en blanc pour éviter que le
             colorAccent du thème ne teinte la barre en couleur. -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/exo_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:bar_height="5dp"
            app:played_color="#FFFFFFFF"
            app:scrubber_color="#FFFFFFFF"
            app:unplayed_color="#33FFFFFF"
            app:buffered_color="#CCFFFFFF"
            app:scrubber_enabled_size="14dp"
            app:scrubber_disabled_size="0dp"
            app:scrubber_dragged_size="22dp"
            app:touch_target_height="32dp" />

        <!-- Custom barre 1 (chunk en lecture) — visible pour live IPTV -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/live_primary_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Custom barre 2 (chunk pré-chargé) — visible pour live IPTV -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/live_secondary_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:focusable="false"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <!-- 2026-06-19 v34 (user "barre avec TOUS les icônes tout en haut") :
         exo_bottom_bar ne contient plus QUE le timer (position/separator/
         duration). channel_list a été déplacée dans exo_top_icons_bar
         pour grouper TOUS les icônes en haut. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/exo_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/exo_progress_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/exo_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="00:00:00" />

        <TextView
            android:id="@+id/tv_time_separator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="·"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/exo_position"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/exo_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_time_separator"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="00:00:00" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 2026-06-19 v37 (user "ta barre avec le cadenas et tout le reste elle
         devrait être en haut") : container TOP des icônes — alignée TOUT EN
         HAUT à droite, sur la même ligne que le titre (au lieu d'être sous
         le subtitle). Le titre se contrainte End_toStartOf=cette bar pour
         ne pas overlap. -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/exo_top_icons_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 2026-06-20 : les boutons ci-dessous sont MASQUÉS (gone) et déplacés
             dans le popup 3-dots. Ils restent dans le layout pour le ViewBinding
             + les fonctionnalités existantes (cast SDK, record state, etc.). -->
        <ImageView
            android:id="@+id/btn_exo_lock"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:src="@drawable/exo_styled_controls_lock"
            app:tint="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription,PrivateResource" />

        <androidx.mediarouter.app.MediaRouteButton
            android:id="@+id/btn_exo_cast"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:mediaRouteButtonTint="#FFFFFF" />

        <ImageView
            android:id="@+id/btn_exo_wireless"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:src="@drawable/ic_screen_share"
            app:tint="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="PrivateResource" />

        <ImageView
            android:id="@+id/btn_exo_picture_in_picture"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:src="@drawable/exo_styled_controls_picture_in_picture"
            app:tint="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription,PrivateResource" />

        <ImageView
            android:id="@+id/btn_live_record"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:src="@android:drawable/ic_menu_save"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/btn_exo_aspect_ratio"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:src="@drawable/exo_styled_controls_aspect_ratio"
            app:tint="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription,PrivateResource" />

        <ImageView
            android:id="@+id/btn_exo_external_player"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:src="@drawable/exo_styled_controls_external_player"
            app:tint="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription" />

        <!-- IPTV only — channel list icon (reste visible si IPTV) -->
        <ImageView
            android:id="@+id/btn_exo_channel_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:padding="12dp"
            android:src="@drawable/ic_channel_list"
            android:contentDescription="Liste des chaines"
            android:visibility="gone"
            app:tint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_exo_server"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 2026-06-20 : bouton Serveur — toujours visible,
             accès direct au picker de serveurs sans passer par les 3-dots. -->
        <ImageView
            android:id="@+id/btn_exo_server"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:padding="12dp"
            android:src="@drawable/ic_server_swap"
            android:contentDescription="Changer de serveur"
            app:tint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/exo_settings"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 2026-06-20 : 3-dots → ouvre un popup menu avec TOUTES les
             options (lock, cast, wireless, PiP, record, ratio, externe,
             paramètres). L'ID reste exo_settings pour le wiring. -->
        <ImageView
            android:id="@+id/exo_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:src="@drawable/ic_overflow_menu"
            android:contentDescription="Plus d'options"
            app:tint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 2026-06-19 v34 (user "passer l'intro en bas, pas en haut") :
         BUG TROUVÉ — la contrainte référençait exo_progress qui est DANS
         exo_progress_container (LinearLayout), pas direct child du
         ConstraintLayout root → contrainte non résolue → bouton tombait
         en haut à droite. Fix : référencer exo_bottom_bar (direct child). -->
    <TextView
        android:id="@+id/btn_skip_intro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_skip_intro_button"
        android:drawableStart="@drawable/exo_styled_controls_fastforward"
        android:drawablePadding="8dp"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="@string/player_skip_intro"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/exo_bottom_bar"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/btn_exo_unlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:padding="12dp"
        android:src="@drawable/exo_styled_controls_unlock"
        app:tint="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="ContentDescription,PrivateResource"
        tools:visibility="visible" />

    <!-- 2026-06-12 (user "le cadenas ne verrouille pas vraiment tout — il
         peut encore toucher la progress bar, les fleches prev/next,
         changer de chaine") : Group ÉTENDU pour couvrir TOUS les boutons
         et widgets interactifs du controller. Le `btn_exo_lock` (=
         interrupteur) et le `btn_exo_unlock` (= déverrouillage) restent
         EN DEHORS du Group → ils restent les seuls cliquables en mode
         verrouillé. Le `exo_bottom_bar` couvrait déjà les boutons
         à droite mais pas les boutons custom prev/next ni les
         widgets ajoutés post-asm161 ; on les liste explicitement. -->
    <androidx.constraintlayout.widget.Group
        android:id="@+id/g_controls_lock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:constraint_referenced_ids="btn_exo_back,tv_exo_title,tv_exo_subtitle,btn_exo_external_player,exo_center_controls,exo_progress,exo_bottom_bar,btn_custom_prev,btn_custom_next,btn_exo_channel_list,btn_exo_cast,btn_exo_wireless,btn_exo_picture_in_picture,btn_live_record,btn_exo_aspect_ratio,btn_skip_intro,btn_exo_server,exo_settings" />

</androidx.constraintlayout.widget.ConstraintLayout>