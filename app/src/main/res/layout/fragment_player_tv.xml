<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".fragments.player.PlayerTvFragment">

    <com.streamflixreborn.streamflix.ui.PlayerTvView
        android:id="@+id/pv_player"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:controller_layout_id="@layout/content_exo_controller_tv"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        app:show_next_button="false"
        app:show_previous_button="false"
        app:show_subtitle_button="true"
        app:show_timeout="2000"
        app:surface_type="surface_view" />

    <!-- 2026-06-29 RESTAURÉ depuis APK v1.7.226 — système de luminosité TV.
         View noir à alpha variable au-dessus du PlayerView, contrôlé par
         UserPreferences.playerDim (SeekBar PLAYER_DIM dans Paramètres TV).
         alpha=0 = invisible (image normale), alpha=1.0 = écran totalement noir.
         L'overlay ne capte pas le focus → ne bloque pas les contrôles. -->
    <View
        android:id="@+id/view_player_dim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/black"
        android:alpha="0"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="@+id/pv_player"
        app:layout_constraintEnd_toEndOf="@+id/pv_player"
        app:layout_constraintStart_toStartOf="@+id/pv_player"
        app:layout_constraintTop_toTopOf="@+id/pv_player" />

    <com.streamflixreborn.streamflix.fragments.player.settings.PlayerSettingsTvView
        android:id="@+id/settings"
        android:layout_width="350dp"
        android:layout_height="0dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />


    <!-- 2026-05-17 : la 2e seek bar de chargement est maintenant intégrée
         dans le controller player (content_exo_controller_tv.xml) — pas
         d'overlay décoratif ici. -->

    <!-- 2026-05-17 v54 (user "écran noir d'1s au swap") :
         Overlay de freeze frame. Pendant le swap (Codec2 flush Amlogic),
         on PixelCopy la dernière frame du SurfaceView dans cet ImageView
         qu'on affiche par-dessus le player. Le décodeur peut donc reset
         tranquillement sans que l'écran devienne noir. On le cache dès
         que le player retourne STATE_READY. -->
    <ImageView
        android:id="@+id/swap_freeze_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/pv_player"
        app:layout_constraintEnd_toEndOf="@+id/pv_player"
        app:layout_constraintStart_toStartOf="@+id/pv_player"
        app:layout_constraintTop_toTopOf="@+id/pv_player" />

    <!-- 2026-05-11 : Overlay de chargement pendant la recherche servers + extraction
         pour TOUS les providers SAUF IPTV. Visible pendant LoadingServers/Video,
         hidden dès que ExoPlayer STATE_READY ou SuccessLoadingVideo. -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#B3000000"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/loading_overlay_spinner"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:indeterminate="true"
                android:indeterminateTint="#FFFFFF" />

            <TextView
                android:id="@+id/loading_overlay_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Chargement…"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <!-- 2026-05-16 : hint clickable (TV : Bouton OK pour cancel). -->
            <TextView
                android:id="@+id/loading_overlay_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="#33FFFFFF"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"
                android:text="Appuyer sur OK pour changer de serveur"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="italic" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/loading_overlay_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_gravity="bottom"
            android:max="100"
            android:progress="0"
            android:progressTint="#FFFFFF" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_next_episode_overlay"
        android:layout_width="316dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_next_episode_overlay"
        android:clickable="true"
        android:elevation="20dp"
        android:focusable="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/settings"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/iv_next_episode_poster"
            android:layout_width="96dp"
            android:layout_height="54dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@drawable/glide_fallback_cover" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_next_episode_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_next_episode_up_next"
                android:textAllCaps="true"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_next_episode_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="S2 E8" />

            <TextView
                android:id="@+id/tv_next_episode_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                tools:text="Finale" />

            <TextView
                android:id="@+id/tv_next_episode_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                tools:text="Playing next in 8s" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_next_episode_action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_next_episode_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:nextFocusLeft="@id/btn_next_episode_dismiss"
                    android:nextFocusRight="@id/btn_next_episode_dismiss"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    android:text="@string/player_next_episode_action"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btn_next_episode_dismiss"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_next_episode_dismiss"
                    android:clickable="true"
                    android:contentDescription="@string/player_next_episode_dismiss"
                    android:focusable="true"
                    android:nextFocusLeft="@id/btn_next_episode_action"
                    android:nextFocusRight="@id/btn_next_episode_action"
                    android:padding="8dp"
                    android:src="@drawable/ic_player_settings_close"
                    android:tint="?android:attr/textColorPrimary"
                    tools:ignore="UseAppTint" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Channel zapping overlay (IPTV) -->
    <LinearLayout
        android:id="@+id/layout_channel_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/bg_next_episode_overlay"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/iv_channel_logo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@null"
            android:scaleType="centerInside"
            tools:src="@drawable/glide_fallback_cover" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_channel_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3"
                tools:text="5" />

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxWidth="250dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#CCFFFFFF"
                android:textSize="16sp"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                tools:text="France 5" />
        </LinearLayout>
    </LinearLayout>

    <!-- 2026-05-31 : Panel liste des chaînes IPTV (D-pad LEFT) -->
    <LinearLayout
        android:id="@+id/layout_channel_list"
        android:layout_width="360dp"
        android:layout_height="0dp"
        android:background="#DD000000"
        android:elevation="20dp"
        android:focusable="false"
        android:orientation="vertical"
        android:padding="0dp"
        android:visibility="gone"
        android:translationX="-360dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 2026-06-13 (user "on a oublié de mettre un bouton retour pour
             quitter") : ligne titre + bouton retour. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btn_channel_list_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Retour"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#22FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:minWidth="0dp"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <TextView
                android:id="@+id/tv_channel_list_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chaînes"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:gravity="center_vertical" />
        </LinearLayout>

        <!-- 2026-06-13 (user "ajoute une barre de recherche dans l'overlay des
             chaînes IPTV qu'on puisse écrire ce qu'on cherche") :
             EditText focusable D-pad TV + mobile clavier. Filtre live la
             liste des chaînes affichées dans rv_channel_list. -->
        <EditText
            android:id="@+id/et_channel_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:background="#22FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:hint="Rechercher une chaîne…"
            android:textColorHint="#88FFFFFF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_channel_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />
    </LinearLayout>

    <!-- 2026-06-20 (user "comme sur l'image, panel épisodes droite avec saisons +
         cartes riches") : panneau VOD épisodes side-right. Slide depuis la droite,
         saisons en haut, RecyclerView cards riches en bas. Background bindé sur
         le thème (ThemeManager.palette.mobileNavBackground) à l'affichage. -->
    <LinearLayout
        android:id="@+id/layout_episode_panel"
        android:layout_width="420dp"
        android:layout_height="0dp"
        android:background="#EE000000"
        android:elevation="20dp"
        android:focusable="false"
        android:orientation="vertical"
        android:padding="0dp"
        android:visibility="gone"
        android:translationX="420dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Header : titre "Épisodes (N)" + bouton fermer ✕ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tv_episode_panel_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Épisodes"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_episode_panel_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@android:color/transparent"
                android:minWidth="0dp"
                android:padding="0dp"
                android:focusable="true"
                android:focusableInTouchMode="true" />
        </LinearLayout>

        <!-- 2026-06-24 (user "il manque pas VF et VOSTFR en haut, comme sur
             l'image que je t'ai envoyée") : onglets LANGUE au-dessus des
             saisons, visibles UNIQUEMENT si le provider supporte plusieurs
             langues (= AnimeSama / Wiflix et co). GONE par défaut. -->
        <HorizontalScrollView
            android:id="@+id/hsv_episode_lang_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="false"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/ll_episode_lang_tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp" />
        </HorizontalScrollView>

        <!-- Onglets saisons (HorizontalScrollView avec boutons dynamiques) -->
        <HorizontalScrollView
            android:id="@+id/hsv_episode_seasons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/ll_episode_season_tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />
        </HorizontalScrollView>

        <!-- Liste épisodes -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_episode_panel_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_brightness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="32dp"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_brightness_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            tools:text="50%"/>

        <ProgressBar
            android:id="@+id/pb_brightness"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:rotation="270"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="60dp"
            tools:progress="50"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_brightness"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_volume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="32dp"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_volume_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            tools:text="50%"/>

        <ProgressBar
            android:id="@+id/pb_volume"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:rotation="270"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="60dp"
            tools:progress="50"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_player_settings_audio"
            app:tint="#FFFFFF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
