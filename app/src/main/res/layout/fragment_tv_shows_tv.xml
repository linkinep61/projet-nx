<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.tv_shows.TvShowsTvFragment">

    <!-- Boutons mini player — barre HORIZONTALE en HAUT À GAUCHE,
         détachée du mini lecteur. Ordre : ⛶ → ⏸ → ✕ -->
    <LinearLayout
        android:id="@+id/mini_player_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:elevation="8dp"
        android:background="#CC000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="70dp"
        android:layout_marginTop="8dp">

        <ImageView
            android:id="@+id/mini_player_channel_logo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:scaleType="fitCenter"
            tools:ignore="ContentDescription" />

        <ProgressBar
            android:id="@+id/mini_player_loading"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"
            android:indeterminateTintMode="src_in"
            android:indeterminateTint="#FFFFFF" />

        <ImageView
            android:id="@+id/mini_player_fullscreen"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:padding="8dp"
            android:src="@drawable/ic_mini_player_fullscreen"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusRight="@id/mini_player_pause"
            android:nextFocusDown="@id/vgv_tv_shows"
            android:nextFocusLeft="@id/tv_shows"
            android:contentDescription="Agrandir" />

        <ImageView
            android:id="@+id/mini_player_pause"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="4dp"
            android:padding="8dp"
            android:src="@drawable/ic_mini_player_pause"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/mini_player_fullscreen"
            android:nextFocusRight="@id/mini_player_close"
            android:nextFocusDown="@id/vgv_tv_shows"
            android:contentDescription="Pause" />

        <ImageView
            android:id="@+id/mini_player_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/mini_player_pause"
            android:nextFocusDown="@id/vgv_tv_shows"
            android:contentDescription="Fermer"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- Mini Player — vidéo pure, flush top-right. Pas d'overlay dedans. -->
    <FrameLayout
        android:id="@+id/mini_player_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#FF000000"
        android:elevation="8dp"
        app:layout_constraintWidth_percent="0.50"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/mini_player_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:show_buffering="when_playing"
            app:resize_mode="fit" />
    </FrameLayout>

    <!-- Nom de chaîne caché — garde le binding fonctionnel -->
    <TextView
        android:id="@+id/mini_player_channel_name"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/tab_language"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="#1A1A2E"
        android:baselineAligned="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tab_fr"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="FR"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/vgv_tv_shows"
            android:nextFocusRight="@id/tab_vostfr"
            android:background="#33E50914" />

        <TextView
            android:id="@+id/tab_vostfr"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="VOSTFR"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/vgv_tv_shows"
            android:nextFocusLeft="@id/tab_fr"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <!-- 2026-05-13 (user "il n'y a pas l'icône catégorie dans film et dans série") :
         2 boutons IPTV (catégories + filtre langue) top-left. -->
    <LinearLayout
        android:id="@+id/ll_iptv_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_language">

        <ImageView
            android:id="@+id/iv_iptv_categories"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:padding="10dp"
            android:src="@drawable/ic_categories_filter"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusLeft="@id/tv_shows"
            android:nextFocusRight="@id/iv_iptv_language"
            android:nextFocusDown="@id/vgv_tv_shows"
            android:contentDescription="Catégories Séries"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/iv_iptv_language"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_iptv_language"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusLeft="@id/iv_iptv_categories"
            android:nextFocusDown="@id/vgv_tv_shows"
            android:contentDescription="Filtre langue"
            app:tint="@android:color/white" />
    </LinearLayout>

    <androidx.leanback.widget.VerticalGridView
        android:id="@+id/vgv_tv_shows"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:padding="@dimen/tv_shows_spacing"
        android:nextFocusUp="@id/iv_iptv_categories"
        app:focusOutEnd="true"
        app:focusOutFront="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_iptv_actions"
        app:numberOfColumns="8"
        tools:listitem="@layout/item_tv_show_grid" />

    <include
        android:id="@+id/is_loading"
        layout="@layout/layout_is_loading_tv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_language" />

</androidx.constraintlayout.widget.ConstraintLayout>