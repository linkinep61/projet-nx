<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.tv_shows.TvShowsTvFragment">

    <!-- Mini Player container for TV (IPTV only, hidden by default) — top right -->
    <FrameLayout
        android:id="@+id/mini_player_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#FF000000"
        android:elevation="8dp"
        app:layout_constraintWidth_percent="0.45"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp">

        <androidx.media3.ui.PlayerView
            android:id="@+id/mini_player_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:show_buffering="when_playing"
            app:resize_mode="fit" />

        <LinearLayout
            android:id="@+id/mini_player_overlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#80000000"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6dp">

            <ImageView
                android:id="@+id/mini_player_channel_logo"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="6dp"
                android:scaleType="fitCenter"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/mini_player_channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <ProgressBar
                android:id="@+id/mini_player_loading"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="6dp"
                android:visibility="gone"
                android:indeterminateTintMode="src_in"
                android:indeterminateTint="#FFFFFF" />

            <ImageView
                android:id="@+id/mini_player_pause"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:padding="4dp"
                android:src="@drawable/ic_mini_player_pause"
                android:scaleType="fitCenter"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:contentDescription="Pause" />

            <ImageView
                android:id="@+id/mini_player_fullscreen"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:padding="4dp"
                android:src="@drawable/ic_mini_player_fullscreen"
                android:scaleType="fitCenter"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:contentDescription="Fullscreen" />

            <ImageView
                android:id="@+id/mini_player_close"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="4dp"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:scaleType="fitCenter"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:contentDescription="Close"
                app:tint="#FFFFFF" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/tab_language"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="#1A1A2E"
        android:baselineAligned="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tab_fr"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="FR"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/vgv_tv_shows"
            android:nextFocusRight="@id/tab_vostfr"
            android:background="#33E50914" />

        <TextView
            android:id="@+id/tab_vostfr"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="VOSTFR"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/vgv_tv_shows"
            android:nextFocusLeft="@id/tab_fr"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <androidx.leanback.widget.VerticalGridView
        android:id="@+id/vgv_tv_shows"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:padding="@dimen/tv_shows_spacing"
        android:nextFocusUp="@id/tab_fr"
        app:focusOutEnd="true"
        app:focusOutFront="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_language"
        app:numberOfColumns="6"
        tools:listitem="@layout/item_tv_show_grid" />

    <include
        android:id="@+id/is_loading"
        layout="@layout/layout_is_loading_tv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_language" />

</androidx.constraintlayout.widget.ConstraintLayout>