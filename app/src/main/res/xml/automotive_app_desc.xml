<!-- 2026-07-22 (projet Android Auto) : déclaration requise par com.google.android.gms.car.application.
     TECHNIQUE AAAD/CarStream/aabrowser (vérifié par décompilation androguard de
     com.kododake.aabrowser.aaad_ded741 res/oc.xml) : se déclarer comme app MÉDIA
     (<uses name="media"/>) — les apps média sont TOUJOURS listées dans le lanceur Android Auto,
     SANS MediaBrowserService (aabrowser n'en a aucun). Ensuite la catégorie NAVIGATION +
     CAR_LAUNCHER sur SplashActivity fait PROJETER l'activité réelle (vidéo native).
     <uses name="template"/> exigeait une vraie app Car App Library valide → ONYX était rejeté. -->
<automotiveApp>
    <!-- 2026-07-23 : TEMPLATE PUR (voie CarStream). En déclarant media + template, AA classait ONYX
         comme app MÉDIA (navigateur de listes audio) et n'exposait JAMAIS le CarAppService → aucune
         vidéo. Template seul = AA cherche le CarAppService de navigation → OnyxCarVideoScreen obtient
         la surface (ACCESS_SURFACE) et y projette la VIDÉO ExoPlayer. -->
    <uses name="template" />
</automotiveApp>
