<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceScreen
        android:key="screen_provider"
        android:title="@string/settings_category_provider_title"
        android:summary="@string/settings_screen_provider_summary"
        android:widgetLayout="@layout/preference_widget_chevron">

        <PreferenceCategory
            android:key="pc_provider_settings"
            android:title="@string/settings_category_provider_title">

            <EditTextPreference
                android:key="provider_url"
                android:title="@string/settings_category_provider_url"
                android:inputType="textUri" />

            <EditTextPreference
                android:key="provider_portal_url"
                android:title="@string/settings_category_provider_update_url"
                android:inputType="textUri" />

            <SwitchPreference
                android:key="provider_autoupdate"
                android:title="@string/settings_autoupdate"
                android:defaultValue="true"
                android:summaryOn="@string/settings_autoupdate_on"
                android:summaryOff="@string/settings_autoupdate_off" />

            <Preference
                android:icon="@drawable/ic_refresh"
                android:key="provider_autoupdate_now"
                android:title="@string/settings_autoupdate_now" />

            <SwitchPreference
                android:key="pc_frenchstream_new_interface"
                android:title="@string/settings_frenchstream_use_new_interface"
                android:defaultValue="true"
                android:summaryOn="@string/settings_frenchstream_use_new_interface_on"
                android:summaryOff="@string/settings_frenchstream_use_new_interface_off" />
        </PreferenceCategory>

        <PreferenceCategory
            android:key="pc_streamingcommunity_settings"
            android:title="@string/settings_category_streamingcommunity">

            <EditTextPreference
                android:key="provider_streamingcommunity_domain"
                android:title="@string/settings_category_streamingcommunity_domain"
                android:inputType="text" />

            <Preference
                android:key="provider_streamingcommunity_domain_reset"
                android:title="@string/settings_streamingcommunity_domain_reset"
                android:summary="@string/settings_streamingcommunity_domain_reset_summary" />
        </PreferenceCategory>

        <PreferenceCategory
            android:key="pc_cuevana_settings"
            android:title="@string/settings_category_cuevana">

            <EditTextPreference
                android:key="provider_cuevana_domain"
                android:title="@string/settings_category_cuevana_domain"
                android:inputType="text" />
        </PreferenceCategory>

        <PreferenceCategory
            android:key="pc_poseidon_settings"
            android:title="@string/settings_category_poseidon">

            <EditTextPreference
                android:key="provider_poseidon_domain"
                android:title="@string/settings_category_poseidon_domain"
                android:inputType="text" />
        </PreferenceCategory>

        <!-- 2026-05-13 (user "mieux encore c'est d'aller dans les paramètres
             paramètres du fournisseur et mettre les sources IPTV qu'on a ajouté
             dedans voir en ajouter directement d'ici ça fera plus propre") :
             Section Mon IPTV intégrée dans Paramètres du fournisseur.
             Visible uniquement quand current provider == MyIptvProvider. -->
        <PreferenceCategory
            android:key="pc_my_iptv"
            android:title="Mon IPTV">

            <Preference
                android:key="pref_iptv_manage_sources"
                android:title="Mes sources IPTV"
                android:summary="Gérer (ajouter, modifier, supprimer) les sources M3U/Stalker" />

            <Preference
                android:key="pref_iptv_add_source"
                android:title="+ Ajouter une nouvelle source"
                android:summary="Ouvre directement le formulaire d'ajout" />

            <Preference
                android:key="pref_iptv_clear_cache"
                android:title="Vider le cache disque"
                android:summary="Force le re-téléchargement complet de toutes les sources au prochain clic" />

            <!-- 2026-05-13 (user "ça serait bien comme ça on peut avoir vraiment
                 tout le contenu") : choix du filtre langue (Auto / Tout / FR strict). -->
            <ListPreference
                android:key="pref_iptv_language_filter"
                android:title="Filtrer par langue"
                android:summary="Auto : montre tout pour les playlists curées par région, filtre FR pour les gros bouquets multi-pays"
                android:entries="@array/iptv_language_filter_entries"
                android:entryValues="@array/iptv_language_filter_values"
                android:defaultValue="auto" />
        </PreferenceCategory>

        <PreferenceCategory
            android:key="pc_extractor_management"
            android:title="Sources vidéo">

            <!-- 2026-07-13 (user "option au-dessus de Gérer les sources, globale à tous les
                 providers : décochée = seuls les serveurs natifs, tous les backups désactivés"). -->
            <SwitchPreferenceCompat
                android:key="pref_backups_enabled"
                android:title="Activer les backups"
                android:summary="Décoché : seuls les serveurs natifs de chaque provider s'affichent (désactive tous les backups, pour tester les sources natives)"
                android:defaultValue="true" />

            <Preference
                android:key="p_settings_extractor_toggle"
                android:title="Gérer les sources"
                android:summary="Activer/désactiver les extracteurs vidéo, mettre en favori" />

            <Preference
                android:key="refresh_provider_caches"
                android:title="Rafraîchir les caches des providers"
                android:summary="Remet les providers à neuf (caches serveurs, extraction, home). Garde vos favoris et « continuer à regarder ». N'affecte pas les chaînes IPTV." />

            <!-- 2026-07-10 (user "désactiver les backups un par un") : chaque source cochée = active. -->
            <MultiSelectListPreference
                android:key="ENABLED_BACKUPS"
                android:title="Backups actifs"
                android:summary="Décochez une source pour la désactiver (en cas de problème)"
                android:entries="@array/backup_source_labels"
                android:entryValues="@array/backup_source_keys"
                android:defaultValue="@array/backup_source_keys" />

        </PreferenceCategory>

        <PreferenceCategory
            android:key="pc_provider_empty_state"
            android:title="@string/settings_provider_connection_title">

            <Preference
                android:key="provider_no_options"
                android:title="@string/settings_provider_no_options_title"
                android:summary="@string/settings_provider_no_options_summary" />
        </PreferenceCategory>
    </PreferenceScreen>

    <PreferenceScreen
        android:key="screen_content"
        android:title="@string/settings_section_content_title"
        android:summary="@string/settings_screen_content_summary"
        android:widgetLayout="@layout/preference_widget_chevron">

        <PreferenceCategory
            android:key="pc_tmdb_settings"
            android:title="@string/settings_category_tmdb">

            <SwitchPreferenceCompat
                android:key="ENABLE_TMDB"
                android:title="@string/settings_enable_tmdb_title"
                android:summary="@string/settings_enable_tmdb_summary"
                android:defaultValue="true" />

            <EditTextPreference
                android:key="TMDB_API_KEY"
                android:title="@string/settings_tmdb_api_key"
                android:summary="@string/settings_tmdb_api_key_summary"
                android:inputType="text" />
        </PreferenceCategory>

        <PreferenceCategory
            android:key="pc_parental_control_settings"
            android:title="@string/settings_category_parental_control">

            <EditTextPreference
                android:key="PARENTAL_CONTROL_PIN"
                android:title="@string/settings_parental_pin_title"
                android:summary="@string/settings_parental_pin_summary"
                android:inputType="numberPassword" />

            <EditTextPreference
                android:key="PARENTAL_CONTROL_ADMIN_PIN"
                android:title="@string/settings_parental_admin_pin_title"
                android:summary="@string/settings_parental_admin_pin_summary"
                android:inputType="numberPassword" />

            <Preference
                android:key="PARENTAL_CONTROL_REMOVE_PIN"
                android:title="@string/settings_parental_remove_pin_title"
                android:summary="@string/settings_parental_remove_pin_summary" />

            <Preference
                android:key="PARENTAL_CONTROL_REMOVE_ADMIN_PIN"
                android:title="@string/settings_parental_remove_admin_pin_title"
                android:summary="@string/settings_parental_remove_admin_pin_summary" />

            <ListPreference
                android:key="PARENTAL_CONTROL_MAX_AGE"
                android:title="@string/settings_parental_max_age_title"
                android:summary="@string/settings_parental_max_age_summary"
                android:entries="@array/parental_control_age_entries"
                android:entryValues="@array/parental_control_age_values"
                android:defaultValue="" />

            <Preference
                android:key="PARENTAL_CONTROL_UNLOCK"
                android:title="@string/settings_parental_unlock_title"
                android:summary="@string/settings_parental_unlock_summary" />
        </PreferenceCategory>
    </PreferenceScreen>

    <PreferenceScreen
        android:key="screen_playback"
        android:title="@string/player_settings"
        android:summary="@string/settings_screen_playback_summary"
        android:widgetLayout="@layout/preference_widget_chevron">

        <PreferenceCategory android:title="@string/autoplay_settings">

            <!-- 2026-06-10 : décodeur logiciel (fix freeze sur certains TV box). -->
            <SwitchPreference
                android:key="PREFER_SOFTWARE_DECODER"
                android:title="Forcer le décodeur logiciel"
                android:summary="À activer si la lecture freeze (image figée, son OK). Plus lent mais compatible avec tous les formats. Recommandé pour Google TV Streamer / certaines TV box."
                android:defaultValue="false" />

            <!-- 2026-06-10 : sous-titres FR IPTV (dessins animés VOSTFR, etc.) -->
            <SwitchPreference
                android:key="IPTV_SHOW_SUBTITLES_FR"
                android:title="Sous-titres FR sur IPTV"
                android:summary="Affiche automatiquement les sous-titres français quand ils sont disponibles dans le flux (dessin animé VOSTFR, etc.). Désactiver si les CC pour malentendants (HUGO! HUGO!) sont gênants."
                android:defaultValue="false" />

            <SwitchPreference
                android:key="AUTOPLAY"
                android:title="@string/settings_autoplay"
                android:defaultValue="true"
                android:summaryOn="@string/settings_autoplay_on"
                android:summaryOff="@string/settings_autoplay_off" />

            <!-- 2026-06-14 (user "ajoute une option pour désactiver l'overlay
                 épisode suivant pour ceux qui veulent aller jusqu'à la fin") -->
            <SwitchPreference
                android:key="SHOW_NEXT_EPISODE_OVERLAY"
                android:title="Overlay « Épisode suivant »"
                android:summaryOn="L'overlay s'affiche en fin d'épisode pour passer au suivant."
                android:summaryOff="Désactivé : pas d'interruption visuelle, tu peux regarder le générique jusqu'à la fin."
                android:defaultValue="true" />

            <!-- 2026-06-13 (user "l'épisode next en automatique a tendance à
                 sauter les épisodes") : default false = ne saute plus en
                 cascade quand un anime échoue → l'user reprend la main. -->
            <SwitchPreference
                android:key="ANIME_AUTO_SKIP_BROKEN"
                android:title="Saut auto épisode anime cassé"
                android:summaryOn="Si tous les serveurs d'un épisode anime échouent, l'app saute à l'épisode suivant (max 5 sauts en cascade)."
                android:summaryOff="Désactivé : reste sur l'épisode courant et retour à la fiche série au lieu de sauter."
                android:defaultValue="false" />

            <EditTextPreference
                android:key="p_settings_autoplay_buffer"
                android:title="@string/settings_autoplay_buffer_title"
                android:dialogMessage="@string/settings_autoplay_buffer_dialog_message"
                android:defaultValue="3"
                android:inputType="number" />
        </PreferenceCategory>

        <PreferenceCategory
            android:key="pc_extra_buffering_settings"
            android:title="@string/player_settings_extra_buffer_title">

            <SwitchPreference
                android:key="FORCE_EXTRA_BUFFERING"
                android:title="@string/settings_force_extra_buffer_title"
                android:summary="@string/settings_force_extra_buffer_summary"
                android:defaultValue="false" />
        </PreferenceCategory>

        <PreferenceCategory android:title="Affichage">

            <SwitchPreference
                android:key="KEEP_SCREEN_ON_WHEN_PAUSED"
                android:title="@string/settings_keep_screen_on_when_paused"
                android:summary="@string/settings_keep_screen_on_when_paused_summary"
                android:defaultValue="true" />

            <SwitchPreference
                android:key="KEEP_SCREEN_ON_APP"
                android:title="@string/settings_keep_screen_on_app"
                android:summary="@string/settings_keep_screen_on_app_summary"
                android:defaultValue="true" />

            <!-- 2026-06-29 RESTAURÉ depuis APK v1.7.226 — luminosité du LECTEUR.
                 PLAYER_DIM : assombrit l'image du lecteur (utile la nuit).
                 (CAROUSEL_DIM déplacé dans Apparence — il n'a rien à faire ici.) -->
            <SeekBarPreference
                android:key="PLAYER_DIM"
                android:title="Luminosité du lecteur"
                android:summary="Réduire la luminosité de l'image du lecteur (utile la nuit)"
                android:max="100"
                android:defaultValue="0" />
        </PreferenceCategory>

        <PreferenceCategory android:title="Mini Player IPTV">

            <SwitchPreference
                android:key="MINI_PLAYER_ENABLED"
                android:title="Mini Player"
                android:defaultValue="true"
                android:summaryOn="Les chaînes IPTV s'ouvrent dans le mini player"
                android:summaryOff="Les chaînes IPTV s'ouvrent en plein écran" />
        </PreferenceCategory>

        <PreferenceCategory android:title="@string/player_settings">

            <Preference
                android:key="external_player_default"
                android:title="Lecteur externe par défaut"
                android:summary="Aucun — utiliser le lecteur interne (ExoPlayer)" />

            <ListPreference
                android:key="preferred_player"
                android:title="@string/settings_trailer_player_title"
                android:summary="@string/settings_trailer_player_summary"
                android:entries="@array/trailer_player_names"
                android:entryValues="@array/trailer_player_values"
                android:defaultValue="ask" />

            <Preference
                android:key="preferred_player_reset"
                android:title="@string/settings_trailer_player_reset"
                android:summary="@string/settings_trailer_player_reset_summary" />
        </PreferenceCategory>

        <PreferenceCategory
            android:title="@string/settings_server_voe_category">

            <SwitchPreference
                android:key="SERVER_AUTO_SUBTITLES_DISABLED"
                android:title="@string/settings_server_voe_title"
                android:summary="@string/settings_server_voe_summary"
                android:defaultValue="true" />

            <!-- 2026-06-09 (user "Imagine on tombe sur une vidéo française et
                 ça se met à faire des sous titres") : toggle pour désactiver
                 l'overlay sous-titres externe (Vidzy etc.). -->
            <SwitchPreference
                android:key="EXTERNAL_SUBS_OVERLAY_DISABLED"
                android:title="Désactiver l'overlay sous-titres externe"
                android:summary="Désactive l'affichage automatique des VOSTFR récupérés depuis l'extracteur (Vidzy). Utile si la vidéo est déjà en VF."
                android:defaultValue="false" />
        </PreferenceCategory>
    </PreferenceScreen>

    <!-- 2026-06-10 : entrée Mes sources World TV retirée des Paramètres
         (l'user a un bouton "Sources" dans la sidebar TV + un icône sur
         le home mobile, donc redondant). Gestion via WorldLiveSourcesDialog
         accessible depuis ces 2 points. -->


    <PreferenceScreen
        android:key="screen_appearance"
        android:title="@string/settings_category_appearance"
        android:summary="@string/settings_screen_appearance_summary"
        android:widgetLayout="@layout/preference_widget_chevron">

        <PreferenceCategory
            android:title="@string/settings_category_appearance">

            <ListPreference
                android:key="APP_LANGUAGE"
                android:title="@string/settings_app_language_title"
                android:summary="@string/settings_app_language_summary"
                android:defaultValue="system" />

            <ListPreference
                android:key="theme_preference"
                android:title="@string/settings_theme_title"
                android:entries="@array/theme_names"
                android:entryValues="@array/theme_values"
                android:defaultValue="default" />

            <!-- 2026-06-07 (user "il devrait être dans apparence sur TV
                 comme sur mobile") : PROFILE_PICKER_ENABLED déplacé ici
                 depuis la PreferenceCategory "Affichage" du screen_playback. -->
            <SwitchPreference
                android:key="PROFILE_PICKER_ENABLED"
                android:title="@string/settings_profile_picker"
                android:summary="@string/settings_profile_picker_summary"
                android:defaultValue="true" />

            <!-- 2026-06-09 (user "les réglages tu les as pas mis où il faut
                 ils sont censés être dans l'onglet apparence") : toggle
                 global carrousel-comme-fond, déplacé depuis screen_playback. -->
            <!-- 2026-06-21 (user "réunir toutes ces préférences en une seule
                 option pour éviter d'avoir trop de trucs partout") :
                 4 modes regroupés dans UNE seule liste déroulante. -->
            <ListPreference
                android:key="HOME_BG_MODE"
                android:title="Affichage du home"
                android:summary="%s"
                android:entries="@array/home_bg_mode_entries"
                android:entryValues="@array/home_bg_mode_values"
                android:defaultValue="carousel" />

            <!-- 2026-06-29 (user "la luminosité du carrousel c'est dans Apparence,
                 pas dans les paramètres du lecteur") : assombrit UNIQUEMENT le
                 carrousel du home (pas le fond d'écran). -->
            <SeekBarPreference
                android:key="CAROUSEL_DIM"
                android:title="Luminosité du carrousel"
                android:summary="Assombrit uniquement le carrousel du home (utile la nuit)"
                android:max="100"
                android:defaultValue="0" />

            <!-- 2026-07-09 (user "un bouton pour réduire la luminosité de l'application
                 entière, comme le slider du carrousel") : assombrit TOUTE l'app. -->
            <SeekBarPreference
                android:key="APP_DIM"
                android:title="Luminosité de l'application"
                android:summary="Assombrit toute l'application (utile la nuit)"
                android:max="90"
                android:defaultValue="0" />

            <!-- 2026-06-09 : fond d'écran personnalisé. -->
            <Preference
                android:key="WALLPAPER_GALLERY"
                android:title="Galerie en ligne (4K Wallhaven)"
                android:summary="Parcourir des millions de wallpapers HD par mot-clé" />

            <Preference
                android:key="WALLPAPER_PICK"
                android:title="Importer une image perso"
                android:summary="Choisir une image depuis ton appareil (clé USB, photos, Drive, etc.)" />

            <Preference
                android:key="WALLPAPER_CLEAR"
                android:title="Retirer le fond personnalisé"
                android:summary="Revient au fond par défaut de l'application" />

            <ListPreference
                android:key="WALLPAPER_DIM"
                android:title="Assombrir le fond personnalisé"
                android:summary="Pour la lisibilité si l'image est très claire"
                android:entries="@array/wallpaper_dim_names"
                android:entryValues="@array/wallpaper_dim_values"
                android:defaultValue="none" />

            <!-- 2026-06-09 (user "rendre transparente la bande noire") :
                 opacité de la sidebar de navigation TV. -->
            <SeekBarPreference
                android:key="SIDEBAR_OPACITY"
                android:title="Opacité de la barre latérale"
                android:summary="100 = opaque, 0 = totalement transparente (voir le fond d'écran)"
                android:defaultValue="100"
                android:min="0"
                android:max="100" />
        </PreferenceCategory>

        <PreferenceCategory
            android:title="@string/screen_scale_category_title">

            <SeekBarPreference
                android:key="scale_x"
                android:title="@string/screen_scale_x_title"
                android:summary="@string/screen_scale_x_summary"
                android:defaultValue="0"
                android:min="-250"
                android:max="250" />

            <SeekBarPreference
                android:key="scale_y"
                android:title="@string/screen_scale_y_title"
                android:summary="@string/screen_scale_y_summary"
                android:defaultValue="0"
                android:min="-250"
                android:max="250" />
        </PreferenceCategory>
    </PreferenceScreen>

    <PreferenceScreen
        android:key="screen_network"
        android:title="@string/settings_category_network_title"
        android:summary="@string/settings_screen_network_summary"
        android:widgetLayout="@layout/preference_widget_chevron">

        <PreferenceCategory
            android:key="pc_network_settings"
            android:title="@string/settings_category_network_title">

            <ListPreference
                android:key="p_doh_provider_url"
                android:title="@string/settings_doh_provider_title"
                android:summary="%s"
                android:entries="@array/doh_provider_names"
                android:entryValues="@array/doh_provider_urls"
                android:defaultValue="https://cloudflare-dns.com/dns-query" />

            <EditTextPreference
                android:key="HLS_PROXY_URL"
                android:title="HLS Proxy URL"
                android:summary="Cloudflare Worker URL pour contourner le blocage FAI (cfglobalcdn)"
                android:inputType="textUri" />
        </PreferenceCategory>

        <PreferenceCategory
            android:key="pc_subdl_settings"
            android:title="@string/settings_category_subdl">

            <EditTextPreference
                android:key="SUBDL_API_KEY"
                android:title="@string/settings_subdl_api_key"
                android:summary="@string/settings_subdl_api_key_summary"
                android:inputType="text" />
        </PreferenceCategory>
    </PreferenceScreen>

    <PreferenceScreen
        android:key="screen_backup"
        android:title="@string/backup_category_title"
        android:summary="@string/settings_screen_backup_summary"
        android:widgetLayout="@layout/preference_widget_chevron">

        <PreferenceCategory
            android:title="@string/backup_category_title">

            <Preference
                android:key="key_backup_export_tv"
                android:title="@string/backup_export_title"
                android:summary="@string/backup_export_summary" />

            <Preference
                android:key="key_backup_import_tv"
                android:title="@string/backup_import_title"
                android:summary="@string/backup_import_summary" />

            <Preference
                android:key="key_backup_refresh_cache_tv"
                android:title="@string/settings_refresh_cache_title"
                android:summary="@string/settings_refresh_cache_summary" />

            <Preference
                android:key="key_backup_export_db_tv"
                android:title="@string/backup_db_export_title"
                android:summary="@string/backup_db_export_summary" />

            <Preference
                android:key="key_backup_import_db_tv"
                android:title="@string/backup_db_import_title"
                android:summary="@string/backup_db_import_summary" />

            <Preference
                android:key="key_device_sync_tv"
                android:title="Synchroniser avec un autre appareil"
                android:summary="Transfère tes données entre téléphone et TV via un code" />
        </PreferenceCategory>
    </PreferenceScreen>

    <PreferenceCategory
        android:title="@string/miscelaneous_title">

        <Preference
            android:icon="@drawable/ic_telegram"
            android:key="p_settings_telegram"
            android:title="@string/settings_telegram" />

        <Preference
            android:key="p_settings_extractor_stats"
            android:title="Extracteurs"
            android:summary="Liste des extracteurs ayant échoué (rapport bug)" />

        <SwitchPreference
            android:key="UPDATE_CHECK_ENABLED"
            android:title="@string/settings_update_check"
            android:summary="@string/settings_update_check_summary"
            android:defaultValue="true" />

        <Preference
            android:icon="@drawable/ic_favorite_enable"
            android:key="p_settings_kofi"
            android:title="Soutenir le projet"
            android:summary="Offrez un café au développeur sur Ko-fi" />

        <Preference
            android:icon="@drawable/ic_settings_about"
            android:key="p_settings_about"
            android:title="@string/settings_about" />
    </PreferenceCategory>

</androidx.preference.PreferenceScreen>
