<?xml version="1.0" encoding="utf-8"?>
<!-- Carte "+ Ajouter" : neutre + bordure pointillée pour bien la différencier
     des avatars colorés. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="#22000000" />
    <stroke android:width="2dp" android:color="#88FFFFFF" android:dashWidth="6dp" android:dashGap="4dp" />
    <corners android:radius="28dp" />
</shape>
