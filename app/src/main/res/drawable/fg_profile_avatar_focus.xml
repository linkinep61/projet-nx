<?xml version="1.0" encoding="utf-8"?>
<!-- Foreground sélecteur : superpose un anneau blanc épais + un voile clair
     uniquement quand le tile est focusé. Permet de garder le gradient coloré
     en background visible tout le temps. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#22FFFFFF" />
            <stroke android:width="5dp" android:color="#FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</selector>
