<?xml version="1.0" encoding="utf-8"?>
<!-- 2026-06-22 v5 (user "le Player il devrait être comme les 2 autres logos
     de chaque côté, juste l'icône, et quand on passe dessus on voit bien
     quel cercle qu'on est dessus") :
     même comportement que bg_btn_exoplayer_tv (= boutons latéraux) :
     transparent au repos, halo blanc 50% au focus. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="#80FFFFFF" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="#80FFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
