<?xml version="1.0" encoding="utf-8"?>
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:showIn="@layout/activity_main_tv">

    <item
        android:id="@id/search"
        android:icon="@drawable/ic_menu_search"
        android:title="@string/main_menu_search" />

    <item
        android:id="@id/home"
        android:icon="@drawable/ic_menu_tv"
        android:title="@string/main_menu_home" />

    <!-- 2026-05-13 (user "ça éviterait d'avoir des icônes partout") : items
         iptv_categories et iptv_sources retirés. Le picker de catégorie s'ouvre
         automatiquement au clic sur TV/Films/Séries. Mes sources est désormais
         accessible via Paramètres → Paramètres du fournisseur → Mon IPTV. -->

    <item
        android:id="@id/movies"
        android:icon="@drawable/ic_menu_movie"
        android:title="@string/main_menu_movies" />

    <item
        android:id="@id/tv_shows"
        android:icon="@drawable/ic_menu_series"
        android:title="@string/main_menu_tv_shows" />

    <!-- 2026-05-14 (user "les icônes de la barre de gauche ne correspondent pas
         au provider en général pour les animés tu m'as mis des icônes pour un
         provider IPTV") : les 3 items IPTV sont invisibles par défaut. Le code
         Java (updateNavigationVisibility) ne les affiche QUE pour les providers
         IPTV (Favoris) / MyIptv (Catégories) / MyIptv+Vavoo (Pays-langue). -->
    <item
        android:id="@+id/iptv_favorites"
        android:icon="@drawable/ic_favorite_enable"
        android:title="@string/main_menu_favorites"
        android:visible="false" />

    <item
        android:id="@+id/iptv_categories_menu"
        android:icon="@drawable/ic_categories_filter"
        android:title="Catégories"
        android:visible="false" />

    <item
        android:id="@+id/iptv_language_menu"
        android:icon="@drawable/ic_iptv_language"
        android:title="Pays/langue"
        android:visible="false" />

    <item
        android:id="@id/settings"
        android:icon="@drawable/ic_menu_settings"
        android:title="@string/main_menu_settings" />

    <!-- 2026-05-21 (user "le bouton il aurait fallu le mettre en dessous de
         Paramètres sur TV") : filtre catalogue (Cloudstream / providers TMDB).
         Item sidebar sous Paramètres, invisible par défaut — affiché par
         updateNavigationVisibility() seulement si CatalogFilter.isSupported. -->
    <item
        android:id="@+id/catalog_filter_menu"
        android:icon="@drawable/ic_categories_filter"
        android:title="Filtre"
        android:visible="false" />

</menu>