<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android Auto : surface plein écran pour projeter la vidéo (technique app NAVIGATION, CarStream). -->
    <uses-permission android:name="androidx.car.app.ACCESS_SURFACE" />
    <uses-permission android:name="androidx.car.app.NAVIGATION_TEMPLATES" />
    <uses-permission android:name="androidx.car.app.MAP_TEMPLATES" />
    <!-- 2026-05-31 : Google Cast — découverte Chromecast sur le réseau local -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- 2026-06-09 : audio radio en arrière-plan (écran éteint) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- 2026-06-13 : UPDATE_PACKAGES_WITHOUT_USER_ACTION retire — Google
         Play Protect tagait l'app comme dangereuse a cause de cette permission
         combinee a REQUEST_INSTALL_PACKAGES (= pattern dropper malware).
         Aucun impact UX : on n'utilisait PAS PackageInstaller API (= notre
         InAppUpdater.installApk passe par Intent.ACTION_VIEW qui demande
         TOUJOURS confirmation user, peu importe les permissions). Verifie
         par grep complet : 0 usage code, 0 lib externe. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Pre-Android 10 only: needed to write to /sdcard/Movies/ via legacy File API.
         Android 10+ uses MediaStore via ContentResolver (no permission needed). -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
        <!-- Package visibility for PlanetVPN (= "VPN 2") — sans ça getPackageInfo
             échoue silencieusement et le picker croit que l'app n'est pas installée. -->
        <package android:name="com.freevpnplanet" />
        <!-- Package visibility for SmartTube (Stable & Beta) and YouTube -->
        <package android:name="org.smarttube.stable" />
        <package android:name="org.smarttube.beta" />
        <package android:name="com.google.android.youtube" />
        <package android:name="com.google.android.tv.youtube" />

        <!-- Generic Video Players Visibility -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="video/*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/x-mpegURL" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/vnd.apple.mpegurl" />
        </intent>

        <!-- Intent queries for YouTube links -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" android:host="www.youtube.com" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" android:host="youtu.be" />
        </intent>

    </queries>

    <application
        android:name=".StreamFlixApp"
        android:allowBackup="true"
        android:banner="@mipmap/ic_banner"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:logo="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true">

        <!-- 2026-06-18 (user "la face de connexion pour M6 et TF1") :
             activité WebView fullscreen pour login TF1+ ou M6 6play.
             Intercepte les cookies de session après login. -->
        <activity
            android:name=".activities.LoginWebViewActivity"
            android:configChanges="orientation|screenLayout|screenSize|smallestScreenSize|keyboard|keyboardHidden"
            android:exported="false"
            android:label="Connexion Replay"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- 2026-07-06 : splash animé = point d'entrée (mobile + TV). Il route
             ensuite vers MainMobileActivity ou MainTvActivity selon le device. -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/SplashLaunch"
            android:configChanges="orientation|screenLayout|screenSize|smallestScreenSize|keyboard|keyboardHidden|navigation">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.main.MainMobileActivity"
            android:configChanges="orientation|screenLayout|screenSize|smallestScreenSize"
            android:exported="true"
            android:supportsPictureInPicture="true"
            android:theme="@style/AppTheme.SplashScreen">
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>

                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>

                <data android:scheme="streamflix"
                        android:host="resolve"/>
            </intent-filter>
        </activity>

        <!-- 2026-05-12 : écran "Qui regarde ?" (Netflix-style) lancé par
             MainMobileActivity quand aucun profil n'est actif. -->
        <activity
            android:name=".activities.profile.ProfilePickerActivity"
            android:exported="false"
            android:configChanges="orientation|screenLayout|screenSize|smallestScreenSize"
            android:theme="@style/AppTheme.Mobile" />

        <!-- 2026-05-12 : équivalent TV — lancé par MainTvActivity. -->
        <activity
            android:name=".activities.profile.ProfilePickerTvActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Tv" />

        <!-- 2026-05-12 : gestion des sources IPTV custom (MyIptvProvider). -->
        <activity
            android:name=".activities.iptv.IptvSourcesActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Mobile" />

        <activity
            android:name=".activities.tools.QrScannerActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Mobile" />

        <!-- 2026-06-09 : galerie en ligne Wallhaven pour fonds d'écran perso. -->
        <activity
            android:name=".activities.WallhavenGalleryActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Mobile" />

        <!-- 2026-06-10 : import fichier local JSON pour World Live (SAF picker). -->
        <activity
            android:name=".activities.WorldLiveFileImportActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Transparent" />

        <activity
            android:name=".activities.sync.DeviceSyncActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Mobile" />

        <activity
            android:name=".activities.tools.BypassWebViewActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Mobile" />

        <activity
            android:name=".activities.tools.FranimeCaptureActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:theme="@style/AppTheme.Mobile" />

        <activity
            android:name=".activities.tools.PapadustreamCaptchaActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:theme="@style/AppTheme.Mobile" />

        <activity
            android:name=".activities.tools.NetMirrorWebPlayerActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <activity
            android:name=".activities.tools.LocalPlayerActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/AppTheme.Mobile" />

        <!-- 2026-06-04 : Activity OTF dédiée — utilise ExoPlayer 2.19.1 strict
             pattern OTF TV V3.2 (le reste de l'app reste sur Media3 1.8.0). -->
        <activity
            android:name=".activities.player.OtfPlayerActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout"
            android:screenOrientation="sensorLandscape"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen" />
        <!-- 2026-07-05 : OtfPlayerTvActivity (variante TV) manquait dans ce manifest "default"
             → crash ActivityNotFoundException à l'ouverture d'OTF sur la Chromecast (APP_LAYOUT=default).
             Copiée depuis tv/AndroidManifest.xml. -->
        <activity
            android:name=".activities.player.OtfPlayerTvActivity"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen" />

        <activity
            android:name=".activities.main.MainTvActivity"
            android:exported="true"
            android:theme="@style/AppTheme.Tv" />

        <!-- ═══════════════ Android Auto — ONYX sur l'écran de voiture ═══════════════
             CarAppService catégorie NAVIGATION → Android Auto donne une surface plein écran
             (ACCESS_SURFACE) sur laquelle OnyxCarVideoScreen projette la vidéo (miroir du player
             téléphone). ⚠ HostValidator = ALLOW_ALL (dev) → à durcir si un jour distribué via Play. -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />
        <meta-data
            android:name="androidx.car.app.minCarApiLevel"
            android:value="7" />
        <service
            android:name=".car.OnyxCarAppService"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.NAVIGATION" />
            </intent-filter>
        </service>

        <service
            android:name=".download.DownloadService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- 2026-06-09 : keep-alive radio en arrière-plan -->
        <service
            android:name=".services.RadioPlaybackService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

        <!-- 2026-07-07 : Ecran crash — process séparé, survit au kill du main -->
        <activity
            android:name=".CrashActivity"
            android:process=":crash"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen" />

        <!-- 2026-05-31 : Google Cast SDK — envoie le flux vidéo à la Chromecast -->
        <meta-data
            android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
            android:value="com.streamflixreborn.streamflix.utils.CastOptionsProvider" />

    </application>


</manifest>
